<div class="client-card @(Active ? "client-active" : "") @(Class)" style="@Style">
    <div class="client-card-header">
        <div class="client-card-icon" style="@IconStyle">
            @if (!string.IsNullOrEmpty(IconImage))
            {
                <img src="@IconImage" style="width:100%;height:100%;object-fit:contain;"/>
            }
            else if (!string.IsNullOrEmpty(IconClass))
            {
                <i class="@IconClass"></i>
            }
        </div>
        <div class="client-card-meta" style="@MetaStyle">
            <span class="client-card-name">@Name</span>
            <span class="client-card-sub">@SubContent</span>
        </div>
        <div class="client-card-actions">
            @Actions
        </div>
    </div>
    @if (!string.IsNullOrEmpty(Error))
    {
        <span class="error-text" style="padding:0 2px;">@Error</span>
    }
    @if (!string.IsNullOrEmpty(Description))
    {
        <p class="client-card-desc">@Description</p>
    }
    else if (DescriptionContent != null)
    {
        <p class="client-card-desc">@DescriptionContent</p>
    }
</div>

@code {
    [Parameter] public string Name        { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string Error       { get; set; } = "";
    [Parameter] public string IconImage   { get; set; } = "";
    [Parameter] public string IconClass   { get; set; } = "";
    [Parameter] public string IconStyle   { get; set; } = "padding:5px;";
    [Parameter] public string MetaStyle   { get; set; } = "";
    [Parameter] public bool   Active      { get; set; } = false;
    [Parameter] public string Class       { get; set; } = "";
    [Parameter] public string Style       { get; set; } = "";
    [Parameter] public RenderFragment? SubContent { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public RenderFragment? DescriptionContent { get; set; }

    private string? _lastName;
    private string? _lastDescription;
    private string? _lastError;
    private string? _lastIconImage;
    private string? _lastIconClass;
    private string? _lastIconStyle;
    private string? _lastMetaStyle;
    private bool? _lastActive;
    private string? _lastClass;
    private string? _lastStyle;
    private RenderFragment? _lastSubContent;
    private RenderFragment? _lastActions;
    private RenderFragment? _lastDescriptionContent;

    protected override bool ShouldRender()
    {
        var should = _lastName != Name
                  || _lastDescription != Description
                  || _lastError != Error
                  || _lastIconImage != IconImage
                  || _lastIconClass != IconClass
                  || _lastIconStyle != IconStyle
                  || _lastMetaStyle != MetaStyle
                  || _lastActive != Active
                  || _lastClass != Class
                  || _lastStyle != Style
                  || !ReferenceEquals(_lastSubContent, SubContent)
                  || !ReferenceEquals(_lastActions, Actions)
                  || !ReferenceEquals(_lastDescriptionContent, DescriptionContent);

        _lastName = Name;
        _lastDescription = Description;
        _lastError = Error;
        _lastIconImage = IconImage;
        _lastIconClass = IconClass;
        _lastIconStyle = IconStyle;
        _lastMetaStyle = MetaStyle;
        _lastActive = Active;
        _lastClass = Class;
        _lastStyle = Style;
        _lastSubContent = SubContent;
        _lastActions = Actions;
        _lastDescriptionContent = DescriptionContent;

        return should;
    }
}
