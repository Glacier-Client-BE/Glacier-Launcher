@inject IJSRuntime JS
@inject SettingsService SettingsService
@implements IAsyncDisposable

@* Player skin display. Defaults to a reliable static body render (mc-heads), with
   an opt-in interactive 3D model (skinview3d) that renders the selected cape and a
   chosen arm model (Steve/Alex). The 3D path falls back to the static view if WebGL
   is unavailable. *@

<div class="skin-viewer">
    <div class="skin-stage">
        @if (_mode == "3d")
        {
            <canvas id="@_canvasId" class="skin-canvas"></canvas>
            @if (!_ready) { <div class="skin-loading"><span class="spinner"></span></div> }
        }
        else
        {
            <img class="skin-body" src="@BodyRenderUrl" alt="@DisplayName skin"
                 onerror="this.onerror=null;this.src='@FallbackRenderUrl';" />
        }
    </div>

    <div class="skin-pills" @onmousedown:stopPropagation>
        <button class="skin-pill @(_mode == "2d" ? "active" : "")" @onclick='() => SetMode("2d")'>2D</button>
        <button class="skin-pill @(_mode == "3d" ? "active" : "")" @onclick='() => SetMode("3d")'>3D</button>
        <span class="skin-pill-sep"></span>
        <button class="skin-pill @(_model == "default" ? "active" : "")" @onclick='() => SetModel("default")' data-tooltip="Classic model">Steve</button>
        <button class="skin-pill @(_model == "slim" ? "active" : "")" @onclick='() => SetModel("slim")' data-tooltip="Slim model">Alex</button>
        @if (!string.IsNullOrEmpty(CapeUrl) && _mode == "3d")
        {
            <button class="skin-pill" @onclick="CycleCape" data-tooltip="Cape / Elytra / Off">
                <i class="fa-solid fa-feather"></i> @CapeLabel
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public string Uuid     { get; set; } = "";
    [Parameter] public string Username { get; set; } = "";
    [Parameter] public string CapeUrl  { get; set; } = "";
    // Cache-bust token: bumped by the launcher whenever the skin is changed, so
    // mc-heads/crafatar URLs stop being served from the WebView's HTTP cache.
    [Parameter] public long   Version  { get; set; }
    // The exact PNG the launcher just uploaded (glacier-files.local URL). When
    // set, the 3D model renders THIS texture — instantly correct even while the
    // third-party render CDNs still cache the old skin.
    [Parameter] public string LocalSkinUrl { get; set; } = "";

    private readonly string _canvasId = "skin-" + Guid.NewGuid().ToString("N")[..8];
    private string _mode        = "2d";       // 2d (static image) | 3d (interactive)
    private string _model       = "default";  // default = Steve | slim = Alex
    private bool   _ready;
    private bool   _need3dInit;
    private string _capeMode    = "cape";     // cape | elytra | off
    private string _appliedCape = "";
    private long   _appliedVersion;
    private string _appliedLocalSkin = "";
    private bool   _paramsSeen;

    private string CleanUuid         => (Uuid ?? "").Replace("-", "").Trim();
    private string DisplayName       => string.IsNullOrWhiteSpace(Username) ? "Player" : Username;
    private string VersionQuery      => Version > 0 ? $"?v={Version}" : "";
    private string SkinTextureUrl    => !string.IsNullOrEmpty(LocalSkinUrl)
                                        ? LocalSkinUrl
                                        : $"https://mc-heads.net/skin/{CleanUuid}{VersionQuery}";
    private string BodyRenderUrl     => $"https://mc-heads.net/body/{CleanUuid}/right{VersionQuery}";
    private string FallbackRenderUrl => $"https://crafatar.com/renders/body/{CleanUuid}?overlay&scale=10{(Version > 0 ? $"&v={Version}" : "")}";
    private string CapeLabel         => _capeMode switch { "elytra" => "Elytra", "off" => "No cape", _ => "Cape" };

    // Restore the viewer's last mode/model/cape choice instead of always
    // starting from 2D/Steve/Cape.
    protected override void OnInitialized()
    {
        _mode     = SettingsService.Settings.SkinViewerMode;
        _model    = SettingsService.Settings.SkinViewerModel;
        _capeMode = SettingsService.Settings.SkinViewerCapeMode;
        if (_mode == "3d") _need3dInit = true;
    }

    // A cape selected in the wardrobe arrives via CapeUrl. Show it on the model —
    // which means switching to 3D, since the static render can't display capes.
    protected override void OnParametersSet()
    {
        bool first = !_paramsSeen;
        _paramsSeen = true;

        if (CapeUrl != _appliedCape)
        {
            _appliedCape = CapeUrl;
            if (!first)
            {
                // A genuinely new cape equip (mid-session) — jump to 3D and show
                // it so the change is obviously visible.
                if (!string.IsNullOrEmpty(CapeUrl))
                {
                    _mode = "3d"; _ready = false; _capeMode = "cape"; _need3dInit = true;
                }
                else if (_mode == "3d")
                {
                    _need3dInit = true;   // re-init to drop the cape
                }
            }
            else if (_mode == "3d")
            {
                _need3dInit = true;   // first load already in 3D — make sure init runs
            }
        }

        if (Version != _appliedVersion || LocalSkinUrl != _appliedLocalSkin)
        {
            _appliedVersion   = Version;
            _appliedLocalSkin = LocalSkinUrl;
            // React when the skin changes DURING the viewer's life (the user
            // just applied one) — and on first mount when the change is only
            // minutes old, because the 2D CDN render likely still shows the
            // old skin while the local texture is exactly what was uploaded.
            if (!first)
            {
                if (!string.IsNullOrEmpty(LocalSkinUrl)) { _mode = "3d"; _ready = false; }
                if (_mode == "3d") _need3dInit = true;
                // 2D needs nothing: the <img> src string changed, so the
                // browser refetches on its own.
            }
            else if (!string.IsNullOrEmpty(LocalSkinUrl) && IsRecentChange())
            {
                _mode = "3d"; _ready = false; _need3dInit = true;
            }
        }
    }

    private bool IsRecentChange()
    {
        if (Version <= 0 || Version > DateTime.MaxValue.Ticks) return false;
        return (DateTime.UtcNow - new DateTime(Version, DateTimeKind.Utc)) < TimeSpan.FromMinutes(10);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_need3dInit)
        {
            _need3dInit = false;
            await Init3d();
        }
    }

    private async Task SetMode(string mode)
    {
        if (_mode == mode) return;
        _mode = mode; _ready = false;
        SettingsService.Settings.SkinViewerMode = mode;
        SettingsService.Save();
        if (mode == "3d") _need3dInit = true;
        else { try { await JS.InvokeVoidAsync("glacierSkin.dispose", _canvasId); } catch { } }
        StateHasChanged();
    }

    private async Task SetModel(string model)
    {
        if (_model == model) return;
        _model = model;
        SettingsService.Settings.SkinViewerModel = model;
        SettingsService.Save();
        if (_mode == "3d" && _ready)
        {
            try { await JS.InvokeAsync<bool>("glacierSkin.setModel", _canvasId, SkinTextureUrl, _model); } catch { }
        }
        else
        {
            _mode = "3d"; _ready = false; _need3dInit = true;   // jump to 3D so the change is visible
            SettingsService.Settings.SkinViewerMode = "3d";
            SettingsService.Save();
        }
        StateHasChanged();
    }

    private async Task Init3d()
    {
        bool ok;
        var cape = _capeMode == "off" ? "" : CapeUrl;
        try { ok = await JS.InvokeAsync<bool>("glacierSkin.render", _canvasId, SkinTextureUrl, cape, _model); }
        catch { ok = false; }

        if (ok && _capeMode == "elytra" && !string.IsNullOrEmpty(CapeUrl))
        {
            try { await JS.InvokeAsync<bool>("glacierSkin.setCape", _canvasId, CapeUrl, "elytra"); } catch { }
        }
        if (!ok) _mode = "2d";
        _ready = true;
        StateHasChanged();
    }

    private async Task CycleCape()
    {
        _capeMode = _capeMode switch { "cape" => "elytra", "elytra" => "off", _ => "cape" };
        SettingsService.Settings.SkinViewerCapeMode = _capeMode;
        SettingsService.Save();
        try { await JS.InvokeAsync<bool>("glacierSkin.setCape", _canvasId, CapeUrl, _capeMode); } catch { }
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("glacierSkin.dispose", _canvasId); } catch { }
    }
}
