<div class="dl-progress-row">
    @if (Progress > 0)
    {
        <div class="progress-bar-wrap" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="@((int)Progress)">
            <div class="progress-bar-fill" style="width:@(Progress.ToString("F0"))%"></div>
        </div>
        <span class="dl-pct">@((int)Progress)%</span>
    }
    @if (ShowSpinner)
    {
        <button type="button" class="icon-btn" disabled aria-busy="true"><span class="spinner"></span></button>
    }
</div>

@code {
    [Parameter] public double Progress    { get; set; }
    [Parameter] public bool   ShowSpinner { get; set; } = true;
}
