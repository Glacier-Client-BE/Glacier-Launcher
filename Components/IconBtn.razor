<button type="button"
        class="@(Ghost ? "icon-btn icon-btn-ghost" : "icon-btn") @(Class)"
        data-tooltip="@Title"
        aria-label="@Title"
        aria-busy="@(Loading ? "true" : "false")"
        disabled="@Disabled"
        @onclick="OnClick"
        @onclick:stopPropagation
        @onmousedown:stopPropagation>
    @if (Loading) { <span class="spinner"></span> }
    else if (!string.IsNullOrEmpty(Icon)) { <i class="@Icon"></i> }
    else { @ChildContent }
</button>

@code {
    [Parameter] public string Icon       { get; set; } = "";
    [Parameter] public string Title      { get; set; } = "";
    [Parameter] public string Class      { get; set; } = "";
    [Parameter] public bool   Ghost      { get; set; } = false;
    [Parameter] public bool   Disabled   { get; set; } = false;
    [Parameter] public bool   Loading    { get; set; } = false;
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string? _lastIcon;
    private string? _lastTitle;
    private string? _lastClass;
    private bool? _lastGhost;
    private bool? _lastDisabled;
    private bool? _lastLoading;
    private RenderFragment? _lastChildContent;

    protected override bool ShouldRender()
    {
        var should = _lastIcon != Icon
                  || _lastTitle != Title
                  || _lastClass != Class
                  || _lastGhost != Ghost
                  || _lastDisabled != Disabled
                  || _lastLoading != Loading
                  || !ReferenceEquals(_lastChildContent, ChildContent);

        _lastIcon = Icon;
        _lastTitle = Title;
        _lastClass = Class;
        _lastGhost = Ghost;
        _lastDisabled = Disabled;
        _lastLoading = Loading;
        _lastChildContent = ChildContent;

        return should;
    }
}
