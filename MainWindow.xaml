<Window x:Class="GlacierLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pages="clr-namespace:GlacierLauncher.Pages"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        Title="Glacier Launcher"
        Width="740" Height="500"
        MinWidth="500" MinHeight="360"
        WindowStyle="None"
        Background="#23272a"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      UseAeroCaptionButtons="False"
                      GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Grid WindowChrome.IsHitTestVisibleInChrome="True">
        <blazor:BlazorWebView x:Name="blazorWebView"
                              HostPage="wwwroot/index.html"
                              Services="{DynamicResource services}">
            <blazor:BlazorWebView.RootComponents>
                <blazor:RootComponent Selector="#app"
                                      ComponentType="{x:Type pages:Home}"/>
            </blazor:BlazorWebView.RootComponents>
        </blazor:BlazorWebView>
    </Grid>
</Window>