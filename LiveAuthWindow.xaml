<Window x:Class="GlacierLauncher.LiveAuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:webview="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Sign in to Microsoft Account"
        Width="490" Height="640"
        MinWidth="380" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#1e1f22"
        Foreground="#dcddde"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2b2d31" Padding="14,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🔐" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Text="Sign in with your Microsoft account"
                               FontSize="13" FontWeight="SemiBold" Foreground="#ffffff"/>
                    <TextBlock x:Name="StatusLabel"
                               Text="Loading login.live.com…"
                               FontSize="11" Foreground="#9a9b9f" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <webview:WebView2 x:Name="WebView" Grid.Row="1"
                          DefaultBackgroundColor="#1e1f22"/>

        <Border Grid.Row="2" Background="#2b2d31" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancel"
                        Padding="14,5" Background="#3a3c41" Foreground="#dcddde"
                        BorderThickness="0" Cursor="Hand"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
