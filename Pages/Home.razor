                                    <span class="client-card-name">Screenshots</span>
                                    <span class="client-card-sub" style="opacity:0.5;">@javaScreenshots.Count screenshot(s)</span>
                                </div>
                                <div class="client-card-actions">
                                    <button class="icon-btn" data-tooltip="Open folder" @onclick='() => OpenJavaFolder("screenshots")' @onmousedown:stopPropagation><i class="fa-solid fa-folder-open"></i></button>
                                </div>
                            </div>
                        </div>
                        <div class="client-card">
                            <div class="client-card-header">
                                <div class="client-card-icon" style="background:rgba(250,166,26,0.15); color:var(--orange); padding:8px;"><i class="fa-solid fa-drafting-compass"></i></div>
                                <div class="client-card-meta">
                                    <span class="client-card-name">Schematics</span>
                                    <span class="client-card-sub" style="opacity:0.5;">@javaSchematics.Count file(s)</span>
                                </div>
                                <div class="client-card-actions">
                                    <button class="icon-btn" data-tooltip="Open folder" @onclick='() => OpenJavaFolder("schematics")' @onmousedown:stopPropagation><i class="fa-solid fa-folder-open"></i></button>
                                </div>
                            </div>
