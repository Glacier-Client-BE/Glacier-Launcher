@page "/"
@using GlacierLauncher.Services
@using GlacierLauncher.Models
@inject GameLauncher Launcher
@inject FlarialService Flarial
@inject OderSoService OderSo
@inject AutoUpdateService AutoUpdate
@inject SettingsService SettingsService
@inject DiscordRpcService Discord
@inject CurseForgeService CurseForge
@inject VanillaVersionService VanillaVersions
@inject StoreInstallService StoreInstall
@inject XboxProfileService Xbox
@inject JavaVersionService JavaVersions
@inject JavaGameLauncher JavaLauncher
@inject JavaInstallService JavaInstaller
@inject JavaInstanceService JavaInstances
@inject JavaModLoaderService JavaLoaders
@inject LunarBadlionService LunarBadlion
@inject ModrinthService Modrinth
@inject IJSRuntime JS
@implements IDisposable

<div class="window">
    <div class="window-bg" style="background-image: url('images/bg.jpg');"></div>
    <div class="drag-zone" @onmousedown="OnDragStart"></div>

    <!-- Drop overlay -->
    <div class="drop-zone-overlay">
        <i class="fa-solid fa-file-arrow-down"></i>
        <span>Drop your DLL</span>
        <small>Saved to clients folder and selected automatically</small>
    </div>

    <!-- â”€â”€ GLOBAL SEARCH OVERLAY â”€â”€ -->
    @if (searchOpen)
    {
        <div class="search-overlay" @onclick="CloseSearch">
            <div class="search-modal" @onclick:stopPropagation>
                <div class="search-modal-input-row">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input class="search-modal-input"
                           placeholder="Search clients, versions, settings..."
                           value="@searchQuery"
                           @oninput="OnSearchInput"
                           @onkeydown:stopPropagation />
                    <span class="search-modal-esc">ESC</span>
                </div>
                <div class="search-results">
                    @if (!searchResults.Any())
                    {
                        @if (string.IsNullOrEmpty(searchQuery))
                        {
                            <div class="search-category">Quick Actions</div>
                            @for (int si = 0; si < _defaultSearchResults.Count; si++)
                            {
                                var r = _defaultSearchResults[si];
                                var idx = si;
                                <div class="search-result-item @(searchSelIdx == idx ? "sel" : "")"
                                     @onclick="r.OnSelect"
                                     @onmouseenter="() => searchSelIdx = idx">
                                    <div class="search-result-icon">
                                        @if (r.Icon.StartsWith("images/")) { <img src="@r.Icon" style="width:16px;height:16px;object-fit:contain;" /> }
                                        else { <i class="@r.Icon"></i> }
                                    </div>
                                    <div class="search-result-text">
                                        <span class="search-result-label">@r.Label</span>
                                        @if (!string.IsNullOrEmpty(r.Sub)) { <span class="search-result-sub">@r.Sub</span> }
                                    </div>
                                    @if (!string.IsNullOrEmpty(r.Shortcut))
                                    {
                                        <div class="kbs"><kbd>@r.Shortcut</kbd></div>
                                    }
                                    <span class="search-result-enter">â†µ</span>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="search-no-results">No results for "<strong>@searchQuery</strong>"</div>
                        }
                    }
                    else
                    {
                        int flatIdx = 0;
                        @foreach (var grp in _searchGroups)
                        {
                            <div class="search-category">@grp.Category</div>
                            @foreach (var r in grp.Results)
                            {
                                var fi = flatIdx++;
                                <div class="search-result-item @(searchSelIdx == fi ? "sel" : "")"
                                     @onclick="r.OnSelect"
                                     @onmouseenter="() => searchSelIdx = fi">
                                    <div class="search-result-icon">
                                        @if (r.Icon.StartsWith("images/")) { <img src="@r.Icon" style="width:16px;height:16px;object-fit:contain;" /> }
                                        else { <i class="@r.Icon"></i> }
                                    </div>
                                    <div class="search-result-text">
                                        <span class="search-result-label">@r.Label</span>
                                        @if (!string.IsNullOrEmpty(r.Sub)) { <span class="search-result-sub">@r.Sub</span> }
                                    </div>
                                    <span class="search-result-enter">â†µ</span>
                                </div>
                            }
                        }
                    }
                </div>
            </div>
        </div>
    }

    <!-- â”€â”€ LAUNCHER UPDATE MODAL â”€â”€ -->
    @if (launcherUpdateModalOpen && launcherUpdateInfo != null)
    {
        <div class="modal-overlay" @onclick="CloseUpdateModal">
            <div class="modal-box update-modal" @onclick:stopPropagation>
                <div class="modal-header">
                    <span class="modal-title">
                        <i class="fa-solid fa-rocket" style="color:var(--accent);margin-right:8px;"></i>
                        Update Available
                    </span>
                    <button class="modal-close-btn" @onclick="CloseUpdateModal">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="update-version-row">
                        <div class="update-version-chip current">
                            <span class="uvc-label">Current</span>
                            <span class="uvc-tag">v@(AutoUpdateService.CurrentVersion)</span>
                        </div>
                        <i class="fa-solid fa-arrow-right" style="color:var(--text-dim); font-size:12px;"></i>
                        <div class="update-version-chip next">
                            <span class="uvc-label">Latest</span>
                            <span class="uvc-tag">v@(launcherUpdateInfo.Tag)</span>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(launcherUpdateInfo.Changelog))
                    {
                        <div class="update-changelog">
                            <span class="update-changelog-label">What's new</span>
                            <div class="update-changelog-body">@((MarkupString)FormatChangelog(launcherUpdateInfo.Changelog))</div>
                        </div>
                    }

                    @if (launcherUpdating)
                    {
                        <div class="update-progress-wrap">
                            <div class="update-progress-bar">
                                <div class="update-progress-fill" style="width:@(launcherUpdateProgress.ToString("F0"))%"></div>
                            </div>
                            <span class="update-progress-pct">@((int)launcherUpdateProgress)%</span>
                        </div>
                        <p class="modal-desc" style="margin-top:6px;">Downloading update... launcher will restart automatically.</p>
                    }
                    else
                    {
                        <div class="modal-btn-row" style="margin-top:14px;">
                            <button class="modal-btn modal-btn-cancel" @onclick="SkipLauncherUpdate">Skip</button>
                            <button class="modal-btn modal-btn-cancel" @onclick="CloseUpdateModal">Later</button>
                            <button class="modal-btn modal-btn-confirm" @onclick="ApplyLauncherUpdate">
                                <i class="fa-solid fa-download"></i> Install
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- â”€â”€ RESET CONFIRM MODAL â”€â”€ -->
    @if (resetConfirmOpen)
    {
        <div class="modal-overlay" @onclick="CancelResetSettings">
            <div class="modal-box" @onclick:stopPropagation>
                <div class="modal-header">
                    <span class="modal-title">
                        <i class="fa-solid fa-triangle-exclamation" style="color:var(--orange);margin-right:8px;"></i>
                        Reset settings?
                    </span>
                    <button class="modal-close-btn" @onclick="CancelResetSettings">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                <div class="modal-body">
                    <p class="modal-desc">
                        This will clear all your preferences (theme, accent, recently launched, pinned versions, etc).
                        Discord login and downloaded clients are kept.
                    </p>
                    <div class="modal-btn-row" style="margin-top:8px;">
                        <button class="modal-btn modal-btn-cancel" @onclick="CancelResetSettings">Cancel</button>
                        <button class="modal-btn modal-btn-disconnect" @onclick="DoResetSettings">
                            <i class="fa-solid fa-arrow-rotate-left"></i> Reset
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- â”€â”€ DISCORD MODAL â”€â”€ -->
    @if (discordModalOpen)
    {
        <div class="modal-overlay" @onclick="CloseDiscordModal">
            <div class="modal-box" @onclick:stopPropagation>
                <div class="modal-header">
                    <span class="modal-title"><i class="fa-brands fa-discord" style="color:#7289da;margin-right:8px;"></i>Discord Account</span>
                    <button class="modal-close-btn" @onclick="CloseDiscordModal">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                <div class="modal-body">
                    @if (SettingsService.Settings.DiscordLoggedIn)
                    {
                        <p class="modal-desc">Signed in as <strong style="color:var(--text);">@SettingsService.Settings.DiscordUsername</strong>. Username and avatar will sync to Discord Rich Presence.</p>
                        <div class="modal-btn-row">
                            <button class="modal-btn modal-btn-disconnect" @onclick="DisconnectDiscord">Disconnect</button>
                            <button class="modal-btn modal-btn-cancel" @onclick="CloseDiscordModal">Close</button>
                        </div>
                    }
                    else
                    {
                        <p class="modal-desc">Connect your Discord account to sync your username and avatar with Rich Presence.</p>
                        <button class="discord-oauth-btn" @onclick="OpenDiscordOAuth">
                            <i class="fa-brands fa-discord"></i>
                            Continue with Discord
                        </button>
                        <div class="modal-divider">or enter manually</div>
                        <label class="modal-input-label">Discord Username</label>
                        <input class="modal-input" placeholder="username"
                               @bind="discordUsernameInput" @bind:event="oninput"
                               @onkeydown:stopPropagation />
                        <div class="modal-btn-row">
                            <button class="modal-btn modal-btn-cancel" @onclick="CloseDiscordModal">Cancel</button>
                            <button class="modal-btn modal-btn-confirm" @onclick="SaveDiscordManual"
                                    disabled="@(string.IsNullOrWhiteSpace(discordUsernameInput))">Save</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
<!-- â”€â”€ XBOX PROFILE MODAL â”€â”€ -->

    @if (xboxModalOpen)
    {
        <div class="modal-overlay" @onclick="CloseXboxModal">
            <div class="modal-box" @onclick:stopPropagation>
                <div class="modal-header">
                    <span class="modal-title"><i class="fa-solid fa-gamepad" style="color:#107c10;margin-right:8px;"></i>Xbox Profile</span>
                    <button class="modal-close-btn" @onclick="CloseXboxModal">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                <div class="modal-body">
                    @if (Xbox.IsSignedIn)
                    {
                        <div class="xbox-profile-card">
                            @if (!string.IsNullOrEmpty(Xbox.CurrentProfile?.GamerPictureUrl))
                            {
                                <img class="xbox-avatar" src="@Xbox.CurrentProfile.GamerPictureUrl" alt="" />
                            }
                            else
                            {
                                <div class="xbox-avatar xbox-avatar-placeholder"><i class="fa-solid fa-user"></i></div>
                            }
                            <div class="xbox-profile-info">
                                <span class="xbox-gamertag">@Xbox.CurrentProfile?.Gamertag</span>
                                @if (!string.IsNullOrEmpty(Xbox.CurrentProfile?.AccountTier))
                                {
                                    <span class="xbox-tier-badge">@Xbox.CurrentProfile.AccountTier</span>
                                }
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(Xbox.CurrentProfile?.Bio))
                        {
                            <div class="xbox-bio-section">
                                <span class="xbox-bio-label"><i class="fa-solid fa-quote-left" style="margin-right:6px;opacity:0.5;"></i>Bio</span>
                                <p class="xbox-bio-text">@Xbox.CurrentProfile.Bio</p>
                            </div>
                        }
                        <div class="xbox-stats-grid">
                            <div class="xbox-stat-card">
                                <i class="fa-solid fa-trophy" style="color:#f5a623;"></i>
                                <div class="xbox-stat-detail">
                                    <span class="xbox-stat-value">@(string.IsNullOrEmpty(Xbox.CurrentProfile?.Gamerscore) ? "0" : Xbox.CurrentProfile.Gamerscore) G</span>
                                    <span class="xbox-stat-label">Gamerscore</span>
                                </div>
                            </div>
                            <div class="xbox-stat-card">
                                <i class="fa-solid fa-id-badge" style="color:#107c10;"></i>
                                <div class="xbox-stat-detail">
                                    <span class="xbox-stat-value xbox-xuid-val">@(string.IsNullOrEmpty(Xbox.CurrentProfile?.Xuid) ? "â€”" : Xbox.CurrentProfile.Xuid)</span>
                                    <span class="xbox-stat-label">XUID</span>
                                </div>
                            </div>
                        </div>
                        @if (SettingsService.Settings.JavaAccounts.Count > 0)
                        {
                            <span class="panel-section-label">Minecraft accounts</span>
                            @foreach (var account in SettingsService.Settings.JavaAccounts)
                            {
                                <div class="version-row @(SettingsService.Settings.ActiveJavaAccountId == account.Id ? "mcv-active-row" : "")">
                                    <div class="version-meta">
                                        <span class="version-name">@account.MinecraftUsername</span>
                                        <span class="version-sub">@account.Gamertag</span>
                                    </div>
                                    <button class="vcs-btn vcs-btn-ghost" @onclick='() => SwitchJavaAccount(account)' @onmousedown:stopPropagation>
                                        <i class="fa-solid fa-right-left"></i>
                                    </button>
                                    <button class="vcs-btn vcs-btn-ghost" @onclick='() => RemoveJavaAccount(account)' @onmousedown:stopPropagation>
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            }
                        }
                        <div class="modal-btn-row">
                            <button class="modal-btn modal-btn-confirm" @onclick="XboxAddAccount" disabled="@xboxSigningIn">Add Account</button>
                            <button class="modal-btn modal-btn-disconnect" @onclick="XboxSignOut">Sign Out</button>
                            <button class="modal-btn modal-btn-cancel" @onclick="CloseXboxModal">Close</button>
                        </div>
                    }
                    else
                    {
                        <p class="modal-desc">Sign in with your Xbox account to display your gamertag and profile picture.</p>
                        @if (!string.IsNullOrEmpty(Xbox.LastError))
                        {
                            <p class="error-text" style="margin-bottom:12px;">@Xbox.LastError</p>
                        }
                        <button class="xbox-signin-btn @(xboxSigningIn ? "disabled" : "")" @onclick="XboxSignIn" disabled="@xboxSigningIn">
                            @if (xboxSigningIn)
                            {
                                <span class="spinner"></span><span>Signing in...</span>
                            }
                            else
                            {
                                <i class="fa-solid fa-right-to-bracket"></i>
                                <span>Sign in with Microsoft</span>
                            }
                        </button>
                    }
                </div>
            </div>
        </div>
    }

    <!-- â”€â”€ TOP BAR â”€â”€ -->
    <div class="top-bar">
        <div class="branding">
            <img class="logo-icon" src="images/icon.png" alt="" />
            <div class="branding-text">
                <span class="branding-title">Glacier Launcher</span>
                <span class="branding-sub">Glacier Productions</span>
            </div>
            @if (launcherUpdateAvailable)
            {
                <button class="update-pill" @onclick="OpenUpdateModal" @onmousedown:stopPropagation data-tooltip="Launcher update available â€” click to update">
                    <i class="fa-solid fa-arrow-up"></i>
                    <span>Update</span>
                </button>
            }
            else
            {
                <button class="update-pill">
                    <span>v@(AutoUpdateService.CurrentVersion)</span>
                </button>               
            }
        </div>

        <div class="top-bar-spacer"></div>

        <!-- Edition switcher (Bedrock / Java) -->
        <div class="edition-switcher" @onmousedown:stopPropagation data-tooltip="Switch Minecraft edition">
            <button class="edition-tab @(IsBedrock ? "active" : "")"
                    @onclick='() => SetEdition("bedrock")'>
                <i class="fa-solid fa-cube"></i>
                <span>Bedrock</span>
            </button>
            <button class="edition-tab @(IsJava ? "active" : "")"
                    @onclick='() => SetEdition("java")'>
                <i class="fa-brands fa-java"></i>
                <span>Java</span>
            </button>
        </div>

        <!-- Quick client switcher chip (inline, left of controls) -->
        @if (IsBedrock)
        {
        <div class="topbar-client-chip" @onclick="CycleClient" @onmousedown:stopPropagation
             data-tooltip="Click to cycle client (@SettingsService.Settings.SelectedClient)">
            <div class="chip-dot @(mcRunning ? "live" : "")"></div>
            @if (IsImageClient(SettingsService.Settings.SelectedClient))
            {
                <img class="chip-icon" src="@GetClientImagePath(SettingsService.Settings.SelectedClient)" style="width:14px;height:14px;object-fit:contain;" alt="" />
            }
            else
            {
                <i class="chip-icon @(GetClientIcon(SettingsService.Settings.SelectedClient))"></i>
            }
            <span>@SettingsService.Settings.SelectedClient</span>
            <i class="fa-solid fa-chevron-right chip-arrow"></i>
        </div>
        }

        @if (mcRunning)
        {
            <div class="mc-running-pill" data-tooltip="Minecraft is currently running">
                <i class="fa-solid fa-circle"></i>
                <span>MC</span>
            </div>
        }

        <!-- Quick search trigger (inline, left of controls) -->
        <button class="search-trigger" @onclick="OpenSearch" @onmousedown:stopPropagation data-tooltip="Search (Ctrl+K)">
            <i class="fa-solid fa-magnifying-glass"></i>
            <kbd>Ctrl K</kbd>
        </button>

        <div class="window-controls">
            <button class="wnd-btn minimize-btn" @onclick="MinimizeWindow" @onmousedown:stopPropagation data-tooltip="Minimize">
                <i class="fa-solid fa-minus"></i>
            </button>
            <button class="wnd-btn fullscreen-btn" @onclick="ToggleFullscreen" @onmousedown:stopPropagation data-tooltip="@(_isFullscreen ? "Exit fullscreen" : "Fullscreen (F11)")">
                <i class="fa-solid @(_isFullscreen ? "fa-compress" : "fa-expand")"></i>
            </button>
            <button class="wnd-btn maximize-btn" @onclick="MaximizeWindow" @onmousedown:stopPropagation data-tooltip="Maximize">
                <i class="fa-solid fa-square"></i>
            </button>
            <button class="wnd-btn close-btn" @onclick="CloseWindow" @onmousedown:stopPropagation data-tooltip="Close">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
    </div>

    <!-- â”€â”€ MAIN CONTENT â”€â”€ -->
    <div class="main-content @(currentView != "home" ? "panel-open" : "")">
        <div class="btn-row">
            <button class="action-btn @(hoveredBtn == "launch" || isLaunching ? "btn-wide btn-blue" : "btn-sq") @(isLaunching ? "launching" : "")"
                    @onmouseenter='() => SetHover("launch")' @onmouseleave="ClearHover"
                    @onclick="HandleLaunch" @onmousedown:stopPropagation disabled="@isLaunching">
                @if (hoveredBtn == "launch" || isLaunching)
                {
                    @if (isLaunching) { <span class="spinner"></span><span>Launching...</span> }
                    else              { <span>Launch</span> }
                }
                else { <i class="fa-solid fa-play"></i> }
            </button>

            @if (isLaunching)
            {
                <button class="action-btn btn-sq force-close-btn" data-tooltip="Force close launch"
                        @onclick="ForceCloseLaunch" @onmousedown:stopPropagation>
                    <i class="fa-solid fa-stop"></i>
                </button>
            }

            <div class="btn-badge-wrap">
                <button class="action-btn @(hoveredBtn == "settings" ? "btn-wide" : "btn-sq")"
                        @onmouseenter='() => SetHover("settings")' @onmouseleave="ClearHover"
                        @onclick="OpenSettings" @onmousedown:stopPropagation>
                    @if (hoveredBtn == "settings") { <span>Settings</span> }
                    else { <i class="fa-solid fa-gear"></i> }
                </button>
            </div>

            @if (IsBedrock)
            {
                <div class="btn-badge-wrap">
                    <button class="action-btn @(hoveredBtn == "clients" ? "btn-wide" : "btn-sq")"
                            @onmouseenter='() => SetHover("clients")' @onmouseleave="ClearHover"
                            @onclick="OpenClients" @onmousedown:stopPropagation>
                        @if (hoveredBtn == "clients") { <span>Clients</span> }
                        else { <i class="fa-solid fa-puzzle-piece"></i> }
                    </button>
                    @if (clientsHasBadge) { <span class="notification-badge"></span> }
                </div>

                <div class="btn-badge-wrap">
                    <button class="action-btn @(hoveredBtn == "addons" ? "btn-wide" : "btn-sq")"
                            @onmouseenter='() => SetHover("addons")' @onmouseleave="ClearHover"
                            @onclick="OpenAddons" @onmousedown:stopPropagation>
                        @if (hoveredBtn == "addons") { <span>Addons</span> }
                        else { <i class="fa-solid fa-cube"></i> }
                    </button>
                </div>

                <div class="btn-badge-wrap">
                    <button class="action-btn @(hoveredBtn == "servers" ? "btn-wide" : "btn-sq")"
                            @onmouseenter='() => SetHover("servers")' @onmouseleave="ClearHover"
                            @onclick="OpenServers" @onmousedown:stopPropagation>
                        @if (hoveredBtn == "servers") { <span>Servers</span> }
                        else { <i class="fa-solid fa-server"></i> }
                    </button>
                </div>

                <div class="btn-badge-wrap">
                    <button class="action-btn @(hoveredBtn == "mcversions" ? "btn-wide" : "btn-sq")"
                            @onmouseenter='() => SetHover("mcversions")' @onmouseleave="ClearHover"
                            @onclick="OpenMcVersions" @onmousedown:stopPropagation>
                        @if (hoveredBtn == "mcversions") { <span>MC Versions</span> }
                        else { <i class="fa-solid fa-box-archive"></i> }
                    </button>
                </div>
            }
            else
            {
                <div class="btn-badge-wrap">
                    <button class="action-btn @(hoveredBtn == "javaclients" ? "btn-wide" : "btn-sq")"
                            @onmouseenter='() => SetHover("javaclients")' @onmouseleave="ClearHover"
                            @onclick="OpenJavaClients" @onmousedown:stopPropagation>
                        @if (hoveredBtn == "javaclients") { <span>Launchers</span> }
                        else { <i class="fa-solid fa-rocket"></i> }
                    </button>
                </div>

                <div class="btn-badge-wrap">
                    <button class="action-btn @(hoveredBtn == "addons" ? "btn-wide" : "btn-sq")"
                            @onmouseenter='() => SetHover("addons")' @onmouseleave="ClearHover"
                            @onclick="OpenAddons" @onmousedown:stopPropagation>
                        @if (hoveredBtn == "addons") { <span>Mods</span> }
                        else { <i class="fa-solid fa-puzzle-piece"></i> }
                    </button>
                </div>

                <div class="btn-badge-wrap">
                    <button class="action-btn @(hoveredBtn == "javaversions" ? "btn-wide" : "btn-sq")"
                            @onmouseenter='() => SetHover("javaversions")' @onmouseleave="ClearHover"
                            @onclick="OpenJavaVersions" @onmousedown:stopPropagation>
                        @if (hoveredBtn == "javaversions") { <span>Versions</span> }
                        else { <i class="fa-solid fa-box-archive"></i> }
                    </button>
                </div>
            }
        </div>

        @if (currentView == "home")
        {
            <p class="status-msg @(isError ? "error" : "") @(statusVisible ? "visible" : "")">@statusMessage</p>

            @if (isDownloading)
            {
                <div class="launch-dl-bar">
                    <span class="launch-dl-stage">@downloadStage</span>
                    <div class="progress-bar-wrap launch-dl-progress">
                        <div class="progress-bar-fill" style="width:@($"{downloadPct:F0}%")"></div>
                    </div>
                    <span class="dl-pct">@($"{(int)downloadPct}%")</span>
                </div>
            }

            var editionRecents = RecentsForCurrentEdition();
            @if (SettingsService.Settings.ShowRecentlyLaunched && editionRecents.Count > 0)
            {
                <div class="recently-launched">
                    <span class="recently-label">Recent:</span>
                    @foreach (var item in editionRecents.Take(3))
                    {
                        var itemCopy = item;
                        <button class="recent-item"
                                @onclick="() => QuickLaunchRecent(itemCopy)"
                                @onmousedown:stopPropagation>
                            <i class="fa-solid fa-clock-rotate-left"></i>@RecentDisplayLabel(itemCopy)
                        </button>
                    }
                </div>
            }
        }
    </div>

    <!-- â”€â”€ FOOTER â”€â”€ -->
    <div class="footer">
        @{
            var footerProfile = EffectiveProfile();
            var footerName    = footerProfile == "xbox"    ? Xbox.CurrentProfile?.Gamertag ?? ""
                              : footerProfile == "discord" ? SettingsService.Settings.DiscordUsername
                              :                              displayName;
            var footerHandle  = footerProfile == "xbox"    ? "Xbox Live"
                              : footerProfile == "discord" ? "Discord"
                              :                              displayHandle;
            var footerAvatar  = footerProfile == "xbox"    ? "xbox-connected"
                              : footerProfile == "discord" ? "discord-connected"
                              :                              "";
        }
        <div class="footer-profile-area" @onclick="OpenActiveProfileModal" @onmousedown:stopPropagation>
            <img class="avatar @footerAvatar"
                 src="@(GetAvatarSrc())" alt="" />
            <div class="user-info">
                <span class="username">@footerName</span>
                <span class="user-handle">@footerHandle</span>
            </div>
            <button class="profile-switch-btn"
                    title="@ProfileSwitchTooltip()"
                    @onclick:stopPropagation
                    @onclick="CycleProfileDisplay"
                    @onmousedown:stopPropagation>
                <i class="fa-solid fa-arrows-rotate"></i>
            </button>
            @if (footerProfile == "xbox" && Xbox.IsSignedIn)
            {
                <div class="xbox-hover-card">
                    <div class="xbox-hover-header">
                        @if (!string.IsNullOrEmpty(Xbox.CurrentProfile?.GamerPictureUrl))
                        {
                            <img class="xbox-hover-avatar" src="@Xbox.CurrentProfile.GamerPictureUrl" alt="" />
                        }
                        else
                        {
                            <div class="xbox-hover-avatar xbox-hover-avatar-placeholder"><i class="fa-solid fa-user"></i></div>
                        }
                        <div class="xbox-hover-identity">
                            <span class="xbox-hover-gamertag">@Xbox.CurrentProfile?.Gamertag</span>
                            @if (!string.IsNullOrEmpty(Xbox.CurrentProfile?.AccountTier))
                            {
                                <span class="xbox-hover-tier-badge">@Xbox.CurrentProfile.AccountTier</span>
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Xbox.CurrentProfile?.Bio))
                    {
                        <p class="xbox-hover-bio">@Xbox.CurrentProfile.Bio</p>
                    }
                    <div class="xbox-hover-stats">
                        <div class="xbox-hover-stat">
                            <i class="fa-solid fa-trophy" style="color:#f5a623;"></i>
                            <span class="xbox-hover-stat-val">@(string.IsNullOrEmpty(Xbox.CurrentProfile?.Gamerscore) ? "0" : Xbox.CurrentProfile.Gamerscore)</span>
                            <span class="xbox-hover-stat-lbl">Gamerscore</span>
                        </div>
                        <div class="xbox-hover-stat">
                            <i class="fa-solid fa-id-badge" style="color:#107c10;"></i>
                            <span class="xbox-hover-stat-val xbox-hover-xuid">@(string.IsNullOrEmpty(Xbox.CurrentProfile?.Xuid) ? "â€”" : Xbox.CurrentProfile.Xuid)</span>
                            <span class="xbox-hover-stat-lbl">XUID</span>
                        </div>
                    </div>
                    <div class="xbox-hover-footer">
                        <i class="fa-solid fa-gamepad" style="color:#107c10;"></i>
                        <span>Xbox Live</span>
                        <span class="xbox-hover-dot">â€¢</span>
                        <span>Click to manage</span>
                    </div>
                </div>
            }
            else if (footerProfile == "discord" && SettingsService.Settings.DiscordLoggedIn)
            {
                <div class="xbox-hover-card">
                    <div class="xbox-hover-header">
                        @if (!string.IsNullOrEmpty(SettingsService.Settings.DiscordAvatar))
                        {
                            <img class="xbox-hover-avatar" src="@SettingsService.Settings.DiscordAvatar" alt="" />
                        }
                        else
                        {
                            <div class="xbox-hover-avatar xbox-hover-avatar-placeholder"><i class="fa-brands fa-discord"></i></div>
                        }
                        <div class="xbox-hover-identity">
                            <span class="xbox-hover-gamertag">@SettingsService.Settings.DiscordUsername</span>
                        </div>
                    </div>
                    <div class="xbox-hover-footer">
                        <i class="fa-brands fa-discord" style="color:#5865f2;"></i>
                        <span>Discord</span>
                        <span class="xbox-hover-dot">â€¢</span>
                        <span>Click to manage</span>
                    </div>
                </div>
            }
        </div>
        <div class="footer-right">
            @if (Xbox.IsSignedIn)
            {
                <div class="xbox-connected-pill" @onclick="OpenXboxModal" style="cursor:pointer;">
                    <i class="fa-solid fa-gamepad"></i>
                    <span>@Xbox.CurrentProfile?.Gamertag</span>
                </div>
            }
            else
            {
                <button class="xbox-connect-btn" @onclick="OpenXboxModal" @onmousedown:stopPropagation>
                    <i class="fa-solid fa-gamepad"></i>
                    Xbox
                </button>
            }
            
            @if (SettingsService.Settings.DiscordLoggedIn)
            {
                <div class="discord-connected-pill" @onclick="OpenDiscordModal" style="cursor:pointer;">
                    <i class="fa-brands fa-discord"></i>
                    <span>@SettingsService.Settings.DiscordUsername</span>
                </div>
            }
            else
            {
                <button class="discord-connect-btn" @onclick="OpenDiscordModal" @onmousedown:stopPropagation>
                    <i class="fa-brands fa-discord"></i>
                    Connect
                </button>
            }
            <span style="font-size:11px; color:var(--text-dim);">
                <i class="fa-solid fa-clock" style="margin-right:4px;"></i>@GetFooterVersionLabel()
            </span>
        </div>
    </div>

    <!-- Toast container -->
    <div class="toast-container">
        @foreach (var t in _toasts)
        {
            <div class="toast @(t.Kind)">
                <i class="@(t.Icon)"></i>
                @t.Message
            </div>
        }
    </div>

    <!-- News ticker -->
    <div class="news-strip">
        <div class="news-track">
            @foreach (var item in _newsItems)
            {
                <span class="news-item" @onclick='() => OpenUrl(item.Url)'>
                    <i class="@item.Icon"></i>
                    <span class="news-title">@item.Title</span>
                    <span>@item.Subtitle</span>
                </span>
            }
            @foreach (var item in _newsItems)
            {
                <span class="news-item" @onclick='() => OpenUrl(item.Url)'>
                    <i class="@item.Icon"></i>
                    <span class="news-title">@item.Title</span>
                    <span>@item.Subtitle</span>
                </span>
            }
        </div>
    </div>

    <!-- â”€â”€ SETTINGS PANEL â”€â”€ -->
    @if (currentView == "settings")
    {
        <div class="panel-overlay">
            <div class="panel-handle"></div>
            <div class="panel-header">
                <div class="panel-title-wrap">
                    <span class="panel-title">Settings</span>
                    <div class="panel-title-underline"></div>
                </div>
                <div class="panel-header-actions">
                    <button class="panel-back-btn" @onclick="GoHome" @onmousedown:stopPropagation>
                        <i class="fa-solid fa-chevron-down"></i>
                    </button>
                </div>
            </div>

            <div class="versions-client-switcher">
                <button class="vcs-btn @(settingsCategory == "all" ? "active" : "")"
                        @onclick='() => SetSettingsCategory("all")' @onmousedown:stopPropagation>
                    <i class="fa-solid fa-layer-group"></i> All
                </button>
                @if (IsBedrock)
                {
                    <button class="vcs-btn @(settingsCategory == "injection" ? "active" : "")"
                            @onclick='() => SetSettingsCategory("injection")' @onmousedown:stopPropagation>
                        <i class="fa-solid fa-syringe"></i> Inject
                    </button>
                }
                else
                {
                    <button class="vcs-btn @(settingsCategory == "java" ? "active" : "")"
                            @onclick='() => SetSettingsCategory("java")' @onmousedown:stopPropagation>
                        <i class="fa-brands fa-java"></i> Java
                    </button>
                }
                <button class="vcs-btn @(settingsCategory == "appearance" ? "active" : "")"
                        @onclick='() => SetSettingsCategory("appearance")' @onmousedown:stopPropagation>
                    <i class="fa-solid fa-palette"></i> Looks
                </button>
                <button class="vcs-btn @(settingsCategory == "account" ? "active" : "")"
                        @onclick='() => SetSettingsCategory("account")' @onmousedown:stopPropagation>
                    <i class="fa-solid fa-user"></i> Account
                </button>
                <button class="vcs-btn @(settingsCategory == "system" ? "active" : "")"
                        @onclick='() => SetSettingsCategory("system")' @onmousedown:stopPropagation>
                    <i class="fa-solid fa-gear"></i> System
                </button>
            </div>

            <div class="panel-search-wrap">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input class="panel-search-input" placeholder="Filter settingsc"
                       @bind="settingsFilter" @bind:event="oninput"
                       @onkeydown:stopPropagation />
                @if (!string.IsNullOrEmpty(settingsFilter))
                {
                    <button class="panel-search-clear" title="Clear filter" @onclick="ClearSettingsFilter" @onmousedown:stopPropagation>
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                }
            </div>
            <div class="panel-body settings-body">

                @{ var visibleCount = VisibleSettingsCount(); }
                @if (visibleCount == 0)
                {
                    <div class="settings-empty">
                        <i class="fa-regular fa-folder-open"></i>
                        <span class="settings-empty-title">No matching settings</span>
                        <span class="settings-empty-sub">
                            @if (!string.IsNullOrWhiteSpace(settingsFilter))
                            {
                                @($"Nothing matches \"{settingsFilter}\".")
                            }
                            else
                            {
                                @("This category is empty.")
                            }
                        </span>
                        @if (!string.IsNullOrWhiteSpace(settingsFilter))
                        {
                            <button class="vcs-btn" @onclick="ClearSettingsFilter" @onmousedown:stopPropagation>
                                <i class="fa-solid fa-xmark"></i> Clear filter
                            </button>
                        }
                    </div>
                }

                @if (CategoryMatches("injection"))
                {
                <div class="settings-section">
                @if (SectionMatch(("Active client","active client injection vanilla"), ("Injection delay","injection delay wait"), ("Auto-inject","auto inject automatic"), ("Close after launch","close minimize launch")))
                {
                    <span class="panel-section-label">Injection</span>
                }

                <div class="setting-row @(SH("Active client","active client injection vanilla"))">
                    <span class="setting-label">Active client</span>
                    <select class="setting-select" value="@SettingsService.Settings.SelectedClient"
                            @onchange="OnClientChanged" @onclick:stopPropagation>
                        <option value="Latite Client">Latite Client</option>
                        <option value="Flarial Client">Flarial Client</option>
                        <option value="OderSo Client">OderSo Client</option>
                        @if (!string.IsNullOrEmpty(customDllPath))
                        {
                            <option value="Custom DLL">Custom DLL</option>
                        }
                        <option value="Vanilla">Vanilla (no client)</option>
                    </select>
                </div>

                <div class="setting-row @(SH("Injection delay","injection delay wait"))">
                    <div class="setting-meta">
                        <span class="setting-label">Injection delay</span>
                        <span class="setting-hint">
                            How long to wait after game launches before injecting
                            @if (SettingsService.Settings.SelectedClient == "Vanilla")
                            {
                                <span style="color:var(--text-dim); opacity:0.7;"> Â· ignored in Vanilla</span>
                            }
                        </span>
                    </div>
                    <div style="display:flex; align-items:center; gap:8px;">
                        <input type="range" min="500" max="15000" step="500"
                               value="@SettingsService.Settings.InjectionDelayMs"
                               @oninput="OnDelayChanged"
                               disabled="@(SettingsService.Settings.SelectedClient == "Vanilla")" />
                        <span style="font-size:11px; color:var(--text-dim); width:38px; text-align:right;">
                            @(SettingsService.Settings.InjectionDelayMs / 1000.0)s
                        </span>
                    </div>
                </div>

                <div class="setting-row clickable @(SH("Auto-inject","auto inject automatic"))"
                     @onclick='() => ToggleProp(() => SettingsService.Settings.AutoInject = !SettingsService.Settings.AutoInject)'>
                    <div class="setting-meta">
                        <span class="setting-label">Auto-inject</span>
                        <span class="setting-hint">Inject automatically once the game process is detected</span>
                    </div>
                    <div class="toggle @(SettingsService.Settings.AutoInject ? "on" : "")"
                         @onclick:stopPropagation
                         @onclick='() => ToggleProp(() => SettingsService.Settings.AutoInject = !SettingsService.Settings.AutoInject)'></div>
                </div>

                <div class="setting-row clickable @(SH("Close after launch","close minimize launch"))"
                     @onclick='() => ToggleProp(() => SettingsService.Settings.CloseAfterLaunch = !SettingsService.Settings.CloseAfterLaunch)'>
                    <div class="setting-meta">
                        <span class="setting-label">Close after launch</span>
                        <span class="setting-hint">Minimise the launcher once injection succeeds</span>
                    </div>
                    <div class="toggle @(SettingsService.Settings.CloseAfterLaunch ? "on" : "")"
                         @onclick:stopPropagation
                         @onclick='() => ToggleProp(() => SettingsService.Settings.CloseAfterLaunch = !SettingsService.Settings.CloseAfterLaunch)'></div>
                </div>

                </div>
                }

                @if (CategoryMatches("java"))
                {
                <div class="settings-section">
                @if (SectionMatch(("Maximum RAM","ram memory java heap"), ("Minecraft folder","minecraft folder dot directory"), ("Java runtime","java runtime jre jdk javaw")))
                {
                    <span class="panel-section-label">Java Edition</span>
                }

                <div class="setting-row @(SH("Maximum RAM","ram memory java heap"))">
                    <div class="setting-meta">
                        <span class="setting-label">Maximum RAM</span>
                        <span class="setting-hint">Heap size cap for the Minecraft JVM (-Xmx)</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:8px;">
                        <input type="range" min="1024" max="16384" step="512"
                               value="@SettingsService.Settings.JavaMaxRamMb"
                               @oninput="OnJavaRamChanged" />
                        <span style="font-size:11px; color:var(--text-dim); width:50px; text-align:right;">
                            @(SettingsService.Settings.JavaMaxRamMb) MB
                        </span>
                    </div>
                </div>

                <div class="setting-row @(SH("Minimum RAM","ram memory java heap xms"))">
                    <div class="setting-meta">
                        <span class="setting-label">Minimum RAM</span>
                        <span class="setting-hint">Initial heap size for the Minecraft JVM (-Xms)</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:8px;">
                        <input type="range" min="256" max="@SettingsService.Settings.JavaMaxRamMb" step="256"
                               value="@SettingsService.Settings.JavaMinRamMb"
                               @oninput="OnJavaMinRamChanged" />
                        <span style="font-size:11px; color:var(--text-dim); width:50px; text-align:right;">
                            @(SettingsService.Settings.JavaMinRamMb) MB
                        </span>
                    </div>
                </div>

                <div class="setting-row @(SH("Minecraft folder","minecraft folder dot directory"))">
                    <div class="setting-meta">
                        <span class="setting-label">Minecraft folder</span>
                        <span class="setting-hint">Leave empty for the default %APPDATA%\.minecraft</span>
                    </div>
                    <input class="setting-input" type="text"
                           placeholder="%APPDATA%\.minecraft"
                           value="@SettingsService.Settings.JavaMinecraftDir"
                           @onchange="OnJavaMinecraftDirChanged"
                           @onkeydown:stopPropagation />
                </div>

                <div class="setting-row @(SH("Java runtime","java runtime jre jdk javaw"))">
                    <div class="setting-meta">
                        <span class="setting-label">Java runtime (javaw.exe)</span>
                        <span class="setting-hint">Auto-detected from runtime/JAVA_HOME/PATH/registry when blank</span>
                    </div>
                    <input class="setting-input" type="text"
                           placeholder="C:\Program Files\Java\jdk-21\bin\javaw.exe"
                           value="@SettingsService.Settings.JavaRuntimePath"
                           @onchange="OnJavaRuntimeChanged"
                           @onkeydown:stopPropagation />
                </div>

                <div class="setting-row clickable @(SH("Show snapshots","snapshots experimental"))"
                     @onclick='() => ToggleProp(() => SettingsService.Settings.JavaShowSnapshots = !SettingsService.Settings.JavaShowSnapshots)'>
                    <div class="setting-meta">
                        <span class="setting-label">Show snapshots</span>
                        <span class="setting-hint">Include experimental builds in the Versions list</span>
                    </div>
                    <div class="toggle @(SettingsService.Settings.JavaShowSnapshots ? "on" : "")"
                         @onclick:stopPropagation
                         @onclick='() => ToggleProp(() => SettingsService.Settings.JavaShowSnapshots = !SettingsService.Settings.JavaShowSnapshots)'></div>
                </div>

                <div class="setting-row clickable @(SH("Show beta and alpha","beta alpha historical old"))"
                     @onclick='() => ToggleProp(() => SettingsService.Settings.JavaShowHistorical = !SettingsService.Settings.JavaShowHistorical)'>
                    <div class="setting-meta">
                        <span class="setting-label">Show beta &amp; alpha</span>
                        <span class="setting-hint">Include the original pre-release builds</span>
                    </div>
                    <div class="toggle @(SettingsService.Settings.JavaShowHistorical ? "on" : "")"
                         @onclick:stopPropagation
                         @onclick='() => ToggleProp(() => SettingsService.Settings.JavaShowHistorical = !SettingsService.Settings.JavaShowHistorical)'></div>
                </div>

                <div class="setting-row clickable @(SH("Close after launch","close minimize launch java"))"
                     @onclick='() => ToggleProp(() => SettingsService.Settings.CloseAfterLaunch = !SettingsService.Settings.CloseAfterLaunch)'>
                    <div class="setting-meta">
                        <span class="setting-label">Close after launch</span>
                        <span class="setting-hint">Minimise the launcher once the game starts</span>
                    </div>
                    <div class="toggle @(SettingsService.Settings.CloseAfterLaunch ? "on" : "")"
                         @onclick:stopPropagation
                         @onclick='() => ToggleProp(() => SettingsService.Settings.CloseAfterLaunch = !SettingsService.Settings.CloseAfterLaunch)'></div>
                </div>

                <div class="setting-row @(SH("Custom JVM args","jvm args java options garbage collector gc"))">
                    <div class="setting-meta">
                        <span class="setting-label">Custom JVM args</span>
                        <span class="setting-hint">Appended after -Xmx (e.g. -XX:+UseG1GC -Dfile.encoding=UTF-8)</span>
                    </div>
                    <input class="setting-input" type="text"
                           placeholder="(none)"
                           value="@SettingsService.Settings.JavaCustomJvmArgs"
                           @onchange="OnJavaJvmArgsChanged"
                           @onkeydown:stopPropagation />
                </div>

                <div class="setting-row clickable @(SH("Backup saves before launch","world backup saves zip"))"
                     @onclick='() => ToggleProp(() => SettingsService.Settings.JavaBackupSavesBeforeLaunch = !SettingsService.Settings.JavaBackupSavesBeforeLaunch)'>
                    <div class="setting-meta">
                        <span class="setting-label">Backup saves before launch</span>
                        <span class="setting-hint">Creates a zip of the active instance saves folder</span>
                    </div>
                    <div class="toggle @(SettingsService.Settings.JavaBackupSavesBeforeLaunch ? "on" : "")"
                         @onclick:stopPropagation
                         @onclick='() => ToggleProp(() => SettingsService.Settings.JavaBackupSavesBeforeLaunch = !SettingsService.Settings.JavaBackupSavesBeforeLaunch)'></div>
                </div>

                <div class="setting-row clickable @(SH("Fullscreen","window fullscreen resolution"))"
                     @onclick='() => ToggleProp(() => SettingsService.Settings.JavaFullscreen = !SettingsService.Settings.JavaFullscreen)'>
                    <div class="setting-meta">
                        <span class="setting-label">Fullscreen</span>
                        <span class="setting-hint">Adds --fullscreen to Java launches</span>
                    </div>
                    <div class="toggle @(SettingsService.Settings.JavaFullscreen ? "on" : "")"
                         @onclick:stopPropagation
                         @onclick='() => ToggleProp(() => SettingsService.Settings.JavaFullscreen = !SettingsService.Settings.JavaFullscreen)'></div>
                </div>

                <div class="setting-row clickable @(SH("Custom resolution","window fullscreen resolution width height"))"
                     @onclick='() => ToggleProp(() => SettingsService.Settings.JavaUseCustomResolution = !SettingsService.Settings.JavaUseCustomResolution)'>
                    <div class="setting-meta">
                        <span class="setting-label">Custom resolution</span>
                        <span class="setting-hint">Starts windowed Minecraft at the selected size</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:6px;" @onclick:stopPropagation>
                        <input class="setting-input" style="width:70px;" type="number" value="@SettingsService.Settings.JavaWindowWidth" @onchange="OnJavaWindowWidthChanged" @onkeydown:stopPropagation />
                        <input class="setting-input" style="width:70px;" type="number" value="@SettingsService.Settings.JavaWindowHeight" @onchange="OnJavaWindowHeightChanged" @onkeydown:stopPropagation />
                        <div class="toggle @(SettingsService.Settings.JavaUseCustomResolution ? "on" : "")"
                             @onclick='() => ToggleProp(() => SettingsService.Settings.JavaUseCustomResolution = !SettingsService.Settings.JavaUseCustomResolution)'></div>
                    </div>
                </div>

                <div class="setting-row @(SH("Server auto-connect","server port multiplayer quick play"))">
                    <div class="setting-meta">
                        <span class="setting-label">Server auto-connect</span>
                        <span class="setting-hint">Optional --server and --port launch injection</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:6px;">
                        <input class="setting-input" style="width:150px;" type="text" placeholder="server address" value="@SettingsService.Settings.JavaServerAddress" @onchange="OnJavaServerAddressChanged" @onkeydown:stopPropagation />
                        <input class="setting-input" style="width:70px;" type="number" value="@SettingsService.Settings.JavaServerPort" @onchange="OnJavaServerPortChanged" @onkeydown:stopPropagation />
                    </div>
                </div>

                <div class="setting-row @(SH("Open Minecraft folder","minecraft folder dot directory open"))">
                    <div class="setting-meta">
                        <span class="setting-label">Open .minecraft folder</span>
                        <span class="setting-hint">@JavaVersions.MinecraftDir</span>
                    </div>
                    <button class="btn-sm" @onclick="OpenJavaMinecraftFolder" @onmousedown:stopPropagation>
                        <i class="fa-solid fa-folder-open"></i> Open
                    </button>
                </div>

                <div class="setting-row @(SH("Latest crash report","crash report log latest open view java"))">
                    <div class="setting-meta">
                        <span class="setting-label">Latest crash report</span>
                        <span class="setting-hint">@(LatestJavaCrashLabel())</span>
                    </div>
                    <button class="btn-sm" @onclick="OpenLatestJavaCrash" @onmousedown:stopPropagation disabled="@(LatestJavaCrashFile() == null)">
                        <i class="fa-solid fa-bug"></i> Open
                    </button>
                </div>

                </div>
                }

                @if (CategoryMatches("appearance"))
                {
                <div class="settings-section">
                @if (SectionMatch(("Accent colour","accent color theme"), ("Theme preset","theme dark midnight slate ocean forest sunset light"), ("Compact mode","compact dense small"), ("Animations","animations smooth motion"), ("Background blur","blur background"), ("Remember window size","window size remember"), ("Custom background wallpaper","background wallpaper image custom")))
                {
                    <span class="panel-section-label">Appearance</span>
                }

                <div class="setting-row @(SH("Accent colour","accent color theme"))">
                    <div class="setting-meta">
                        <span class="setting-label">Accent colour</span>
                        <span class="setting-hint">Used for buttons, highlights and glows</span>
                    </div>
                    <div class="color-swatches">
                        @foreach (var c in _accentSwatches)
                        {
                            <div class="color-swatch @(SettingsService.Settings.AccentColor == c ? "active" : "")"
                                 style="background:@c;" data-tooltip="@c"
                                 @onclick='() => SetAccent(c)'
                                 @onmousedown:stopPropagation></div>
                        }
                    </div>
                </div>

                <div class="setting-row @(SH("Theme preset","theme dark midnight slate ocean forest sunset light"))">
                    <div class="setting-meta">
                        <span class="setting-label">Theme preset</span>
                        <span class="setting-hint">Background tone â€” affects panels and overlays</span>
                    </div>
                    <select class="setting-select" value="@SettingsService.Settings.ThemePreset"
                            @onchange="OnThemeChanged" @onclick:stopPropagation>
                        <option value="dark">Dark</option>
                        <option value="darker">Darker</option>
                        <option value="midnight">Midnight</option>
                        <option value="slate">Slate</option>
                        <option value="ocean">Ocean</option>
                        <option value="forest">Forest</option>
                        <option value="sunset">Sunset</option>
                        <option value="light">Light</option>
                    </select>
                </div>

                <div class="setting-row clickable @(SH("Compact mode","compact dense small"))"
                     @onclick='() => ToggleProp(() => { SettingsService.Settings.CompactMode = !SettingsService.Settings.CompactMode; _ = JS.InvokeVoidAsync("setCompactMode", SettingsService.Settings.CompactMode); })'>
                    <div class="setting-meta">
                        <span class="setting-label">Compact mode</span>
                        <span class="setting-hint">Tighter spacing â€” fits more on screen</span>
