                    </button>
                    <button class="vcs-btn @(javaModsTab == "assets" ? "active" : "")"
                            @onclick='() => javaModsTab = "assets"' @onmousedown:stopPropagation>
                        <i class="fa-solid fa-image"></i> Assets
                    </button>
                    <button class="vcs-btn @(javaModsTab == "tools" ? "active" : "")"
                            @onclick='() => javaModsTab = "tools"' @onmousedown:stopPropagation>
                        <i class="fa-solid fa-toolbox"></i> Tools
                    </button>
                    <button class="vcs-btn @(javaModsTab == "curseforge" ? "active" : "")"
                            @onclick='() => javaModsTab = "curseforge"' @onmousedown:stopPropagation>
                        <i class="fa-solid fa-fire"></i> CurseForge
                    </button>
                    <button class="vcs-btn @(javaModsTab == "modrinth" ? "active" : "")"
                            @onclick='() => javaModsTab = "modrinth"' @onmousedown:stopPropagation>
