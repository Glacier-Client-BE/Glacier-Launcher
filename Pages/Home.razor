                {
                    <button class="panel-tab" @onclick="OpenClients" @onmousedown:stopPropagation><i class="fa-solid fa-puzzle-piece"></i>Clients</button>
                    <button class="panel-tab active" @onmousedown:stopPropagation><i class="fa-solid fa-cube"></i>Addons</button>
                    <button class="panel-tab" @onclick="OpenServers" @onmousedown:stopPropagation><i class="fa-solid fa-server"></i>Servers</button>
                    <button class="panel-tab" @onclick="OpenMcVersions" @onmousedown:stopPropagation><i class="fa-solid fa-box-archive"></i>MC Versions</button>
                }
                else
                {
                    <button class="panel-tab" @onclick="OpenJavaClients" @onmousedown:stopPropagation><i class="fa-solid fa-rocket"></i>Launchers</button>
                    <button class="panel-tab active" @onmousedown:stopPropagation><i class="fa-solid fa-puzzle-piece"></i>Mods</button>
                    <button class="panel-tab" @onclick="OpenJavaVersions" @onmousedown:stopPropagation><i class="fa-solid fa-box-archive"></i>Versions</button>
