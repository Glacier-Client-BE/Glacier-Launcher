                                    <span class="version-sub" style="font-size:13px; font-weight:600; color:var(--text);">@SettingsService.Settings.JavaActiveVersion</span>
                                </div>
                            </div>

                            <ClientCard Name="Fabric"
                                        IconClass="fa-solid fa-feather"
                                        IconStyle="background:rgba(219,185,137,0.15); color:#dbb989; padding:8px;"
                                        Active="@(SettingsService.Settings.JavaActiveVersion?.Contains("fabric") == true)">
                                <SubContent>
                                    @if (SettingsService.Settings.JavaActiveVersion?.Contains("fabric") == true)
                                    {
                                        <span class="tag-uptodate"><i class="fa-solid fa-circle-check"></i> Active</span>
                                    }
                                    else
                                    {
                                        <span style="opacity:0.5;">Lightweight mod loader</span>
