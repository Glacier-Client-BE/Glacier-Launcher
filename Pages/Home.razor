                                @onclick='() => SetMrCategory(key)' @onmousedown:stopPropagation>
                            <i class="@cat.Icon"></i> @cat.Label
                        </button>
                    }
                </div>

                <div class="panel-search-wrap">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input class="panel-search-input" placeholder="Search Modrinth for mods, modpacks, shaders..."
                           value="@mrSearchQuery"
                           @oninput="OnMrSearchInput"
                           @onkeydown="OnMrSearchKeyDown"
                           @onkeydown:stopPropagation />
                </div>

                <div class="panel-body">
                    @if (mrSearching)
                    {
                        <div style="display:flex; align-items:center; justify-content:center; padding:30px;">
                            <span class="spinner" style="width:18px;height:18px;border-width:2px;"></span>
                            <span style="margin-left:10px; font-size:12px; color:var(--text-dim);">Searching Modrinth...</span>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(mrError))
                    {
                        <div style="padding:20px; text-align:center;">
                            <span class="error-text">@mrError</span>
