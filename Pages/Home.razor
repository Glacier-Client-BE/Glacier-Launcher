                                    <div class="version-meta">
                                        <span class="version-name" style="@(mod.IsDisabled ? "opacity:.55;" : "")">@mod.Name</span>
                                        <span class="version-sub">@(mod.IsDisabled ? "Disabled" : "Enabled") @(string.IsNullOrWhiteSpace(mod.DependencyHint) ? "" : "· " + mod.DependencyHint)</span>
                                    </div>
                                    <button class="vcs-btn vcs-btn-ghost" @onclick='() => ToggleJavaMod(mod)' @onmousedown:stopPropagation>
                                        <i class="fa-solid @(mod.IsDisabled ? "fa-toggle-off" : "fa-toggle-on")"></i>
                                    </button>
                                    <button class="vcs-btn vcs-btn-ghost" @onclick='() => DeleteJavaFile(mod)' @onmousedown:stopPropagation>
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            }
                            <div style="text-align:center; padding:4px;">
                                <button class="btn-sm" @onclick='() => OpenJavaFolder("mods")' @onmousedown:stopPropagation>
                                    <i class="fa-solid fa-folder-open"></i> Open mods folder
                                </button>
                            </div>
                        }
                    }
                    else if (javaModsTab == "assets")
                    {
                        <div class="client-card">
                            <div class="client-card-header">
                                <div class="client-card-icon" style="background:rgba(67,181,129,0.15); color:var(--green); padding:8px;"><i class="fa-solid fa-image"></i></div>
                                <div class="client-card-meta">
                                    <span class="client-card-name">Resource Packs</span>
                                    <span class="client-card-sub" style="opacity:0.5;">@javaResourcePacks.Count pack(s)</span>
                                </div>
                                <div class="client-card-actions">
                                    <button class="icon-btn" data-tooltip="Open folder" @onclick='() => OpenJavaFolder("resourcepacks")' @onmousedown:stopPropagation><i class="fa-solid fa-folder-open"></i></button>
                                </div>
                            </div>
                        </div>
                        <div class="client-card">
                            <div class="client-card-header">
                                <div class="client-card-icon" style="background:rgba(255,200,50,0.15); color:#ffc832; padding:8px;"><i class="fa-solid fa-wand-magic-sparkles"></i></div>
                                <div class="client-card-meta">
                                    <span class="client-card-name">Shader Packs</span>
                                    <span class="client-card-sub" style="opacity:0.5;">@javaShaderPacks.Count pack(s)</span>
                                </div>
                                <div class="client-card-actions">
                                    <button class="icon-btn" data-tooltip="Open folder" @onclick='() => OpenJavaFolder("shaderpacks")' @onmousedown:stopPropagation><i class="fa-solid fa-folder-open"></i></button>
                                </div>
                            </div>
                        </div>
                        <div class="client-card">
                            <div class="client-card-header">
                                <div class="client-card-icon" style="background:rgba(114,137,218,0.15); color:var(--accent); padding:8px;"><i class="fa-solid fa-map"></i></div>
                                <div class="client-card-meta">
                                    <span class="client-card-name">Saves / Worlds</span>
                                    <span class="client-card-sub" style="opacity:0.5;">Open your worlds folder</span>
                                </div>
                                <div class="client-card-actions">
                                    <button class="icon-btn" data-tooltip="Open folder" @onclick='() => OpenJavaFolder("saves")' @onmousedown:stopPropagation><i class="fa-solid fa-folder-open"></i></button>
                                </div>
                            </div>
                        </div>
                        <div class="client-card">
                            <div class="client-card-header">
                                <div class="client-card-icon" style="background:rgba(240,71,71,0.15); color:var(--red); padding:8px;"><i class="fa-solid fa-camera"></i></div>
