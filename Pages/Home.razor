                    <div class="credits-card-meta">
                        <span class="credits-card-name">Glacier Launcher</span>
                        <span class="credits-card-sub">Built by Pepe · Glacier Productions</span>
                    </div>
                    <div class="credits-card-actions">
                        <button class="credits-link-btn" title="GitHub"
                                @onclick='() => OpenUrl("https://github.com/Glacier-Client-BE")' @onmousedown:stopPropagation>
                            <i class="fa-brands fa-github"></i>
                        </button>
                        <button class="credits-link-btn" title="Website"
                                @onclick='() => OpenUrl("https://glacierclient.xyz")' @onmousedown:stopPropagation>
                            <i class="fa-solid fa-globe"></i>
                        </button>
                        <button class="credits-link-btn" title="Discord"
                                @onclick='() => OpenUrl("https://discord.glacierclient.xyz")' @onmousedown:stopPropagation>
                            <i class="fa-brands fa-discord"></i>
                        </button>
                    </div>
                </div>

                <span class="panel-section-label">Clients</span>

                <div class="credits-card">
                    <div class="credits-card-icon" style="padding:6px;"><img src="images/clients/latite.png" style="width:100%;height:100%;object-fit:contain;"/></div>
                    <div class="credits-card-meta">
                        <span class="credits-card-name">Latite Client</span>
                        <span class="credits-card-sub">by Imrglop &amp; contributors</span>
                    </div>
                    <div class="credits-card-actions">
                        <button class="credits-link-btn" title="GitHub Releases"
                                @onclick='() => OpenUrl("https://github.com/Imrglop/Latite-Releases")' @onmousedown:stopPropagation>
                            <i class="fa-brands fa-github"></i>
                        </button>
                        <button class="credits-link-btn" title="Discord"
                                @onclick='() => OpenUrl("https://discord.gg/latite")' @onmousedown:stopPropagation>
                            <i class="fa-brands fa-discord"></i>
                        </button>
                    </div>
                </div>

                <div class="credits-card">
                    <div class="credits-card-icon" style="padding:6px;"><img src="images/clients/flarial.svg" style="width:100%;height:100%;object-fit:contain;"/></div>
                    <div class="credits-card-meta">
                        <span class="credits-card-name">Flarial Client</span>
                        <span class="credits-card-sub">by the Flarial team</span>
                    </div>
                    <div class="credits-card-actions">
                        <button class="credits-link-btn" title="Website"
                                @onclick='() => OpenUrl("https://flarial.xyz")' @onmousedown:stopPropagation>
                            <i class="fa-solid fa-globe"></i>
                        </button>
                        <button class="credits-link-btn" title="Discord"
                                @onclick='() => OpenUrl("https://discord.gg/flarial")' @onmousedown:stopPropagation>
                            <i class="fa-brands fa-discord"></i>
                        </button>
                    </div>
