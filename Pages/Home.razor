    <!-- â”€â”€ SERVERS PANEL â”€â”€ -->
    @if (currentView == "servers")
    {
        <div class="panel-overlay">
            <div class="panel-handle"></div>
            <div class="panel-header">
                <div class="panel-title-wrap">
                    <span class="panel-title">Servers</span>
                    <div class="panel-title-underline"></div>
                </div>
                <div class="panel-header-actions">
                    <button class="panel-icon-btn versions-sort-btn" @onclick="OpenAddServerModal" @onmousedown:stopPropagation
                            data-tooltip="Add a new server">
                        <i class="fa-solid fa-plus"></i>
                        <span>Add</span>
                    </button>
                    <button class="panel-back-btn" @onclick="GoHome" @onmousedown:stopPropagation>
                        <i class="fa-solid fa-chevron-down"></i>
                    </button>
                </div>
            </div>

            <div class="panel-body">
                @if (SettingsService.Settings.SavedServers.Count == 0)
                {
                    <div class="empty-state" style="padding:20px 20px 8px;">
                        <i class="fa-solid fa-server"></i>
                        <span>No saved servers yet</span>
                        <small>Add a Minecraft Bedrock server to quick-launch into it. The current client will be injected before connecting.</small>
                        <button class="btn-sm" style="margin-top:8px;" @onclick="OpenAddServerModal" @onmousedown:stopPropagation>
                            <i class="fa-solid fa-plus"></i> Add server
                        </button>
                    </div>
                }
                else
                {
                    @foreach (var server in SettingsService.Settings.SavedServers)
                    {
                        var s = server;
                        <div class="server-row">
                            <div class="server-icon" style="@GetServerIconStyle(s)">
                                <i class="@GetServerIconClass(s)"></i>
                            </div>
                            <div class="server-meta">
                                <span class="server-name">@s.Name</span>
                                <span class="server-sub">@s.Address:@s.Port</span>
                            </div>
                            <div class="version-actions">
                                <button class="icon-btn icon-btn-ghost" data-tooltip="Edit"
                                        @onclick="() => OpenEditServerModal(s)" @onmousedown:stopPropagation>
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                                <button class="icon-btn icon-btn-ghost" data-tooltip="Delete"
                                        @onclick="() => DeleteServer(s)" @onmousedown:stopPropagation>
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                                <button class="copy-btn" data-tooltip="Copy address"
                                        @onclick="() => CopyServerAddress(s)" @onmousedown:stopPropagation>
                                    <i class="fa-solid fa-copy"></i>
                                </button>
                                <button class="icon-btn" data-tooltip="Launch &amp; connect"
                                        @onclick="() => LaunchServer(s)" @onmousedown:stopPropagation
                                        disabled="@isLaunching">
                                    <i class="fa-solid fa-play"></i>
                                </button>
                            </div>
                        </div>
                    }
                }

                @{ var unsavedSuggestions = _serverSuggestions.Where(IsSuggestionUnsaved).ToList(); }
                @if (unsavedSuggestions.Count > 0)
                {
                    <span class="panel-section-label">Popular</span>
                    @foreach (var sug in unsavedSuggestions)
                    {
                        var s = sug;
                        <div class="server-row">
                            <div class="server-icon" style="@GetServerIconStyle(s)">
                                <i class="@GetServerIconClass(s)"></i>
                            </div>
                            <div class="server-meta">
                                <span class="server-name">@s.Name</span>
                                <span class="server-sub">@s.Address:@s.Port</span>
                            </div>
                            <div class="version-actions">
                                <button class="copy-btn" data-tooltip="Copy address"
                                        @onclick="() => CopyServerAddress(s)" @onmousedown:stopPropagation>
                                    <i class="fa-solid fa-copy"></i>
                                </button>
                                <button class="icon-btn" data-tooltip="Save"
                                        @onclick="() => SaveSuggestedServer(s)" @onmousedown:stopPropagation>
                                    <i class="fa-solid fa-bookmark"></i>
                                </button>
                                <button class="icon-btn" data-tooltip="Launch &amp; connect"
                                        @onclick="() => LaunchServer(s)" @onmousedown:stopPropagation
                                        disabled="@isLaunching">
                                    <i class="fa-solid fa-play"></i>
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="panel-tabs">
                <button class="panel-tab" @onclick="OpenSettings" @onmousedown:stopPropagation><i class="fa-solid fa-gear"></i>Settings</button>
                <button class="panel-tab" @onclick="OpenClients" @onmousedown:stopPropagation><i class="fa-solid fa-puzzle-piece"></i>Clients</button>
                <button class="panel-tab" @onclick="OpenAddons" @onmousedown:stopPropagation><i class="fa-solid fa-cube"></i>Addons</button>
                <button class="panel-tab active" @onmousedown:stopPropagation><i class="fa-solid fa-server"></i>Servers</button>
                <button class="panel-tab" @onclick="OpenMcVersions" @onmousedown:stopPropagation><i class="fa-solid fa-box-archive"></i>MC Versions</button>
                <button class="panel-tab" @onclick="OpenCredits" @onmousedown:stopPropagation><i class="fa-solid fa-heart"></i>Credits</button>
            </div>
        </div>
    }

    <!-- â”€â”€ ADD/EDIT SERVER MODAL â”€â”€ -->
    @if (serverModalOpen)
    {
        <div class="modal-overlay" @onclick="CloseServerModal">
            <div class="modal-box" @onclick:stopPropagation>
                <div class="modal-header">
                    <span class="modal-title">
                        <i class="fa-solid fa-server" style="color:var(--accent);margin-right:8px;"></i>
                        @(editingServer == null ? "Add server" : "Edit server")
                    </span>
                    <button class="modal-close-btn" @onclick="CloseServerModal">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                <div class="modal-body">
                    <label class="modal-input-label">Display name</label>
                    <input class="modal-input" placeholder="My Server"
                           @bind="serverInputName" @bind:event="oninput"
                           @onkeydown:stopPropagation />

                    <label class="modal-input-label" style="margin-top:8px;">Address (IP or hostname)</label>
                    <input class="modal-input" placeholder="play.example.com"
                           @bind="serverInputAddress" @bind:event="oninput"
                           @onkeydown:stopPropagation />

                    <label class="modal-input-label" style="margin-top:8px;">Port</label>
                    <input class="modal-input" type="number" placeholder="19132"
                           @bind="serverInputPort" @bind:event="oninput"
                           @onkeydown:stopPropagation />

                    @if (!string.IsNullOrEmpty(serverInputError))
                    {
                        <span class="error-text" style="display:block;margin-top:6px;">@serverInputError</span>
                    }

                    <div class="modal-btn-row" style="margin-top:14px;">
                        <button class="modal-btn modal-btn-cancel" @onclick="CloseServerModal">Cancel</button>
                        <button class="modal-btn modal-btn-confirm" @onclick="SaveServerModal">
                            <i class="fa-solid fa-floppy-disk"></i> Save
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- â”€â”€ MC VERSIONS PANEL (Vanilla Version Switcher) â”€â”€ -->
    @if (currentView == "mcversions")
    {
        <div class="panel-overlay">
            <div class="panel-handle"></div>
            <div class="panel-header">
                <div class="panel-title-wrap">
                    <span class="panel-title">MC Versions</span>
                    <div class="panel-title-underline"></div>
                </div>
                <div class="panel-header-actions">
                    <button class="panel-icon-btn @(isLoadingMcVersions ? "spinning" : "")"
                            disabled="@isLoadingMcVersions"
                            @onclick="RefreshMcVersionsAsync" @onmousedown:stopPropagation data-tooltip="Refresh">
                        <i class="fa-solid fa-rotate"></i>
                    </button>
                    <button class="panel-back-btn" @onclick="GoHome" @onmousedown:stopPropagation data-tooltip="Back">
                        <i class="fa-solid fa-chevron-down"></i>
                    </button>
                </div>
            </div>

            <div class="mcv-info-bar">
                <i class="fa-solid fa-circle-info"></i>
                <span>Switch between Minecraft Bedrock versions. Sideload requires Developer Mode; the Microsoft Store option below does not.</span>
            </div>

            <!-- â”€â”€ Microsoft Store install (BedrockUpdater method) â”€â”€ -->
            <div class="mcv-store-row">
                <div class="mcv-store-meta">
                    @if (storeInstallBusy)
                    {
                        <span class="mcv-store-title">@storeInstallStage</span>
                        <span class="mcv-store-sub">@storeInstallDetail</span>
                    }
                    else
                    {
                        <span class="mcv-store-title"><i class="fa-brands fa-microsoft" style="margin-right:6px;"></i>Install latest from Microsoft Store</span>
                        <span class="mcv-store-sub">No Developer Mode required. Installs the current Release or Preview.</span>
                    }
                </div>
                @if (storeInstallBusy)
                {
                    <div class="progress-bar-wrap">
                        <div class="progress-bar-fill" style="width:@($"{storeInstallPct:F0}%")"></div>
                    </div>
                    <span class="dl-pct">@($"{(int)storeInstallPct}%")</span>
                    <button class="vcs-btn vcs-btn-ghost" @onclick="CancelStoreInstall" @onmousedown:stopPropagation>Cancel</button>
                }
                else
                {
                    <button class="vcs-btn" @onclick='() => InstallFromStoreAsync(false)' @onmousedown:stopPropagation>Release</button>
                    <button class="vcs-btn vcs-btn-ghost" @onclick='() => InstallFromStoreAsync(true)' @onmousedown:stopPropagation>Preview</button>
                }
            </div>

            <div class="panel-search-wrap">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input class="panel-search-input" placeholder="Filter Minecraft versions..."
                       @bind="mcVersionsFilter" @bind:event="oninput"
                       @onkeydown:stopPropagation />
            </div>

            <div class="panel-body">
                @if (isLoadingMcVersions)
                {
                    <div class="versions-loading"><span class="spinner"></span><span>Fetching Minecraft versions...</span></div>
                }
                else if (mcVersionsList.Count == 0 && !string.IsNullOrEmpty(mcVersionsError))
                {
                    <div class="versions-loading versions-error">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        <span>@mcVersionsError</span>
                        <button class="vcs-btn" style="margin-top:8px;" @onclick="RefreshMcVersionsAsync">
                            <i class="fa-solid fa-rotate"></i> Retry
                        </button>
                    </div>
                }
                else if (mcVersionsList.Count == 0)
                {
                    <div class="versions-loading"><span style="opacity:0.5;">No versions found.</span></div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(mcVersionsError) && mcVersionsList.Count > 0)
                    {
                        <div class="cache-notice"><i class="fa-solid fa-circle-info"></i><span>@mcVersionsError</span></div>
                    }

                    var filtered = FilteredMcVersions.ToList();

                    @if (filtered.Count == 0)
                    {
                        <div class="versions-loading"><span style="opacity:0.5;">No results for "@mcVersionsFilter"</span></div>
                    }

                    var activeList = filtered.Where(v => v.IsActive).ToList();
                    var restList   = filtered.Where(v => !v.IsActive).ToList();

                    @if (activeList.Count > 0)
                    {
                        <span class="panel-section-label">Active</span>
                        @foreach (var v in activeList)
                        {
                            <div class="version-row mcv-active-row">
                                <div class="version-meta">
                                    <div style="display:flex; align-items:center; gap:6px;">
                                        <span class="version-name">Minecraft @v.Version</span>
                                        <span class="tag-active">Active</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(v.ErrorMessage)) { <span class="error-text">@v.ErrorMessage</span> }
                                    else if (v.IsDownloaded) { <span class="version-sub">Ready Â· @v.SizeLabel</span> }
                                </div>
                                @McVersionActions(v)
                            </div>
                        }
                        <span class="panel-section-label">All Versions</span>
                    }

                    @foreach (var v in restList)
                    {
                        <div class="version-row @(!string.IsNullOrEmpty(v.ErrorMessage) ? "error-row" : "")">
                            <div class="version-meta">
                                <span class="version-name">Minecraft @v.Version</span>
                                @if (!string.IsNullOrEmpty(v.ErrorMessage)) { <span class="error-text">@v.ErrorMessage</span> }
                                else if (v.IsDownloaded && !v.IsDownloading) { <span class="version-sub">Ready Â· @v.SizeLabel</span> }
                                else if (!v.IsDownloaded && !v.IsDownloading) { <span class="version-sub">@v.SizeLabel</span> }
                            </div>
                            @McVersionActions(v)
                        </div>
                    }
                }
            </div>

            <div class="panel-tabs">
                <button class="panel-tab" @onclick="OpenSettings" @onmousedown:stopPropagation><i class="fa-solid fa-gear"></i>Settings</button>
                <button class="panel-tab" @onclick="OpenClients" @onmousedown:stopPropagation><i class="fa-solid fa-puzzle-piece"></i>Clients</button>
                <button class="panel-tab" @onclick="OpenAddons" @onmousedown:stopPropagation><i class="fa-solid fa-cube"></i>Addons</button>
                <button class="panel-tab" @onclick="OpenServers" @onmousedown:stopPropagation><i class="fa-solid fa-server"></i>Servers</button>
                <button class="panel-tab active" @onmousedown:stopPropagation><i class="fa-solid fa-box-archive"></i>MC Versions</button>
                <button class="panel-tab" @onclick="OpenCredits" @onmousedown:stopPropagation><i class="fa-solid fa-heart"></i>Credits</button>
            </div>
        </div>
    }
    <!-- â”€â”€ JAVA LAUNCHERS PANEL â”€â”€ -->
    @if (currentView == "javaclients")
    {
        <div class="panel-overlay">
            <div class="panel-handle"></div>
            <div class="panel-header">
                <div class="panel-title-wrap">
