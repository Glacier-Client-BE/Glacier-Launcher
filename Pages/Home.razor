                                </SubContent>
                                <Actions>
                                    <IconBtn Icon="fa-solid fa-download" Title="Install Fabric" Disabled="javaUtilityBusy" OnClick="InstallFabricForActive" />
                                </Actions>
                                <DescriptionContent>
                                    Fast, lightweight mod loader. One click installs the latest stable Fabric loader for your active version.
                                </DescriptionContent>
                            </ClientCard>

                            <ClientCard Name="Quilt"
                                        IconClass="fa-solid fa-layer-group"
                                        IconStyle="background:rgba(147,130,210,0.15); color:#9382d2; padding:8px;"
                                        Active="@(SettingsService.Settings.JavaActiveVersion?.Contains("quilt") == true)">
                                <SubContent>
                                    @if (SettingsService.Settings.JavaActiveVersion?.Contains("quilt") == true)
                                    {
                                        <span class="tag-uptodate"><i class="fa-solid fa-circle-check"></i> Active</span>
                                    }
                                    else
                                    {
                                        <span style="opacity:0.5;">Fabric-compatible fork</span>
                                    }
                                </SubContent>
                                <Actions>
                                    <IconBtn Icon="fa-solid fa-download" Title="Install Quilt" Disabled="javaUtilityBusy" OnClick="InstallQuiltForActive" />
                                </Actions>
                                <DescriptionContent>
                                    Community-driven fork of Fabric with enhanced APIs. Compatible with most Fabric mods out of the box.
                                </DescriptionContent>
                            </ClientCard>

                            <ClientCard Name="Forge"
                                        IconClass="fa-solid fa-hammer"
                                        IconStyle="background:rgba(66,133,244,0.15); color:#4285f4; padding:8px;"
                                        Active="false">
                                <SubContent>
                                    <span style="opacity:0.5;">The classic mod loader</span>
                                </SubContent>
                                <Actions>
                                    <IconBtn Icon="fa-solid fa-download" Title="Download Forge installer" Disabled="javaUtilityBusy" OnClick="DownloadForgeInstaller" />
                                </Actions>
                                <DescriptionContent>
                                    Auto-detects the recommended Forge version for your active Minecraft version and downloads the installer.
                                </DescriptionContent>
                            </ClientCard>

                            <ClientCard Name="NeoForge"
                                        IconClass="fa-solid fa-fire-flame-curved"
                                        IconStyle="background:rgba(255,120,50,0.15); color:#ff7832; padding:8px;"
                                        Active="false">
                                <SubContent>
                                    <span style="opacity:0.5;">Modern Forge fork (1.20.2+)</span>
                                </SubContent>
                                <Actions>
                                    <IconBtn Icon="fa-solid fa-download" Title="Download NeoForge installer" Disabled="javaUtilityBusy" OnClick="DownloadNeoForgeInstaller" />
                                </Actions>
                                <DescriptionContent>
                                    Auto-detects the latest NeoForge version for your active Minecraft version and downloads the installer.
                                </DescriptionContent>
                            </ClientCard>
                        }
                    }
                    else if (javaModsTab == "mods")
                    {
                        @if (javaMods.Count == 0)
                        {
                            <div class="empty-state" style="padding:14px;">
                                <i class="fa-solid fa-puzzle-piece"></i>
                                <span>No local mods</span>
                                <small>Drop jars into the active instance mods folder, or browse CurseForge below.</small>
                                <button class="btn-sm" style="margin-top:6px;" @onclick='() => OpenJavaFolder("mods")' @onmousedown:stopPropagation>
                                    <i class="fa-solid fa-folder-open"></i> Open mods folder
                                </button>
                            </div>
                        }
                        else
