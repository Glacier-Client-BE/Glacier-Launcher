                <span class="panel-section-label">About</span>

                <div class="setting-row @(SH("Keyboard shortcuts","shortcuts keyboard help"))">
                    <div class="setting-meta">
                        <span class="setting-label">Keyboard shortcuts</span>
                        <span class="setting-hint">Ctrl+K search · Ctrl+L launch · Ctrl+1/2/3 panels · Esc close</span>
                    </div>
                    <div class="kbs"><kbd>?</kbd></div>
                </div>

                <div class="setting-row @(SH("Credits","credits about launcher"))">
                    <span class="setting-label">Credits</span>
                    <button class="btn-sm" @onclick="OpenCredits" @onmousedown:stopPropagation>
                        <i class="fa-solid fa-heart"></i> View
                    </button>
                </div>

            </div>
            <div class="panel-tabs">
                <button class="panel-tab active" @onmousedown:stopPropagation><i class="fa-solid fa-gear"></i>Settings</button>
                <button class="panel-tab" @onclick="OpenClients" @onmousedown:stopPropagation><i class="fa-solid fa-puzzle-piece"></i>Clients</button>
                <button class="panel-tab" @onclick="OpenVersions" @onmousedown:stopPropagation><i class="fa-solid fa-clock-rotate-left"></i>Versions</button>
                <button class="panel-tab" @onclick="OpenCredits" @onmousedown:stopPropagation><i class="fa-solid fa-heart"></i>Credits</button>
            </div>
        </div>
    }

    <!-- ── CLIENTS PANEL ── -->
    @if (currentView == "clients")
    {
        <div class="panel-overlay">
            <div class="panel-header">
                <div class="panel-title-wrap">
                    <span class="panel-title">Clients</span>
                    <div class="panel-title-underline"></div>
                </div>
                <div class="panel-header-actions">
                    <button class="panel-back-btn" @onclick="GoHome" @onmousedown:stopPropagation>
                        <i class="fa-solid fa-chevron-down"></i>
                    </button>
                </div>
            </div>
            <div class="panel-body">

                <!-- Flarial -->
                <div class="client-card @(SettingsService.Settings.SelectedClient == "Flarial Client" ? "client-active" : "")">
                    <div class="client-card-header">
                        <div class="client-card-icon" style="padding:5px;"><img src="images/clients/flarial.svg" style="width:100%;height:100%;object-fit:contain;"/></div>
                        <div class="client-card-meta">
                            <span class="client-card-name">Flarial Client</span>
                            <span class="client-card-sub">
                                @if (flarialDownloaded)
                                {
                                    @if (flarialUpToDate) { <span class="tag-uptodate"><i class="fa-solid fa-circle-check"></i> Up to date</span> }
                                    else                  { <span class="tag-outdated"><i class="fa-solid fa-triangle-exclamation"></i> Update available</span> }
                                }
                                else { <span style="opacity:0.5;">Not downloaded</span> }
                            </span>
                        </div>
                        <div class="client-card-actions">
                            @if (SettingsService.Settings.SelectedClient != "Flarial Client" && flarialDownloaded)
                            {
                                <button class="icon-btn" title="Select" @onclick='() => SelectClient("Flarial Client")' @onmousedown:stopPropagation>
                                    <i class="fa-solid fa-check"></i>
                                </button>
                            }
                            @if (flarialDownloading)
                            {
                                <div class="dl-progress-row">
                                    @if (flarialProgress > 0)
                                    {
                                        <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:@(flarialProgress.ToString("F0"))%"></div></div>
                                        <span class="dl-pct">@((int)flarialProgress)%</span>
                                    }
                                    <button class="icon-btn" disabled><span class="spinner"></span></button>
                                </div>
                            }
                            else
                            {
                                @if (!flarialDownloaded || !flarialUpToDate)
                                {
                                    <button class="icon-btn" title="@(flarialDownloaded ? "Update" : "Download")" @onclick="HandleFlarialDownload" @onmousedown:stopPropagation>
                                        <i class="fa-solid @(flarialDownloaded ? "fa-arrow-up" : "fa-download")"></i>
                                    </button>
                                }
                                @if (flarialDownloaded)
                                {
                                    <button class="icon-btn icon-btn-ghost" title="Delete" @onclick="HandleFlarialDelete" @onmousedown:stopPropagation>
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                }
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(flarialError)) { <span class="error-text" style="padding:0 2px;">@flarialError</span> }
                    <p class="client-card-desc">Feature-rich Bedrock client with modules, HUD customization, and active development.</p>
                </div>

                <!-- Latite -->
                <div class="client-card @(SettingsService.Settings.SelectedClient == "Latite Client" ? "client-active" : "")">
                    <div class="client-card-header">
                        <div class="client-card-icon" style="padding:5px;"><img src="images/clients/latite.png" style="width:100%;height:100%;object-fit:contain;"/></div>
                        <div class="client-card-meta">
                            <span class="client-card-name">Latite Client</span>
                            <span class="client-card-sub" style="opacity:0.5;">Versioned GitHub releases</span>
                        </div>
                        <div class="client-card-actions">
                            @if (SettingsService.Settings.SelectedClient != "Latite Client")
                            {
                                <button class="icon-btn" title="Select" @onclick='() => SelectClient("Latite Client")' @onmousedown:stopPropagation>
                                    <i class="fa-solid fa-check"></i>
                                </button>
                            }
                            <button class="icon-btn icon-btn-ghost" style="background:var(--bg-item);" title="View Versions" @onclick="OpenVersions" @onmousedown:stopPropagation>
                                <i class="fa-solid fa-clock-rotate-left"></i>
                            </button>
                        </div>
                    </div>
                    <p class="client-card-desc">Classic Minecraft Bedrock client. Choose a specific release from the Versions panel.</p>
                </div>

                <!-- OderSo -->
                <div class="client-card @(SettingsService.Settings.SelectedClient == "OderSo Client" ? "client-active" : "")">
                    <div class="client-card-header">
                        <div class="client-card-icon" style="padding:5px;"><img src="images/clients/oderso.png" style="width:100%;height:100%;object-fit:contain;"/></div>
                        <div class="client-card-meta">
                            <span class="client-card-name">OderSo Client</span>
                            <span class="client-card-sub">
                                @if (odersoDownloaded)
                                {
                                    @if (odersoUpToDate) { <span class="tag-uptodate"><i class="fa-solid fa-circle-check"></i> Up to date</span> }
                                    else                  { <span class="tag-outdated"><i class="fa-solid fa-triangle-exclamation"></i> Update available</span> }
                                }
                                else { <span style="opacity:0.5;">Not downloaded</span> }
                            </span>
                        </div>
                        <div class="client-card-actions">
                            @if (SettingsService.Settings.SelectedClient != "OderSo Client" && odersoDownloaded)
                            {
                                <button class="icon-btn" title="Select" @onclick='() => SelectClient("OderSo Client")' @onmousedown:stopPropagation>
                                    <i class="fa-solid fa-check"></i>
                                </button>
                            }
                            @if (odersoDownloading)
                            {
                                <div class="dl-progress-row">
                                    @if (odersoProgress > 0)
                                    {
                                        <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:@(odersoProgress.ToString("F0"))%"></div></div>
                                        <span class="dl-pct">@((int)odersoProgress)%</span>
                                    }
                                    <button class="icon-btn" disabled><span class="spinner"></span></button>
                                </div>
                            }
                            else
                            {
                                @if (!odersoDownloaded || !odersoUpToDate)
                                {
                                    <button class="icon-btn" title="@(odersoDownloaded ? "Update" : "Download")" @onclick="HandleOderSoDownload" @onmousedown:stopPropagation>
                                        <i class="fa-solid @(odersoDownloaded ? "fa-arrow-up" : "fa-download")"></i>
                                    </button>
                                }
                                @if (odersoDownloaded)
                                {
                                    <button class="icon-btn icon-btn-ghost" title="Delete" @onclick="HandleOderSoDelete" @onmousedown:stopPropagation>
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                }
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(odersoError)) { <span class="error-text" style="padding:0 2px;">@odersoError</span> }
                    <p class="client-card-desc">OderSo Client — curated Minecraft Bedrock experience by MasonOderSo.</p>
                </div>

                <!-- Custom DLL -->
                @if (!string.IsNullOrEmpty(customDllPath))
                {
                    <div class="client-card @(SettingsService.Settings.SelectedClient == "Custom DLL" ? "client-active" : "")"
                         style="border-left-color:var(--accent);">
                        <div class="client-card-header">
                            <div class="client-card-icon" style="background:var(--accent-bg); color:var(--accent);">
                                <i class="fa-solid fa-file-code"></i>
                            </div>
                            <div class="client-card-meta">
                                <span class="client-card-name">@System.IO.Path.GetFileName(customDllPath)</span>
                                <span class="client-card-sub" style="font-size:10px; max-width:190px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@customDllPath</span>
                            </div>
                            <div class="client-card-actions">
                                <button class="copy-btn @(copiedDllPath ? "copied" : "")" title="Copy path"
                                        @onclick="CopyDllPath" @onmousedown:stopPropagation>
                                    <i class="fa-solid @(copiedDllPath ? "fa-check" : "fa-copy")"></i>
                                </button>
                                <button class="icon-btn" title="Select" @onclick='() => SelectClient("Custom DLL")' @onmousedown:stopPropagation>
                                    <i class="fa-solid fa-check"></i>
                                </button>
                                <button class="icon-btn icon-btn-ghost" title="Remove" @onclick="ClearCustomDll" @onmousedown:stopPropagation>
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            </div>
                        </div>
                        <p class="client-card-desc">Custom DLL loaded via drag-and-drop or file picker.</p>
                    </div>
                }

                <div class="drop-hint-row">
                    <i class="fa-solid fa-file-arrow-down"></i>
                    <span>Drag &amp; drop a DLL onto the window</span>
                    <button class="btn-sm" @onclick="PickDllFile" @onmousedown:stopPropagation style="margin-left:auto;">
                        <i class="fa-solid fa-folder-open"></i> Browse…
                    </button>
                </div>

            </div>
            <div class="panel-tabs">
                <button class="panel-tab" @onclick="OpenSettings" @onmousedown:stopPropagation><i class="fa-solid fa-gear"></i>Settings</button>
                <button class="panel-tab active" @onmousedown:stopPropagation><i class="fa-solid fa-puzzle-piece"></i>Clients</button>
                <button class="panel-tab" @onclick="OpenVersions" @onmousedown:stopPropagation><i class="fa-solid fa-clock-rotate-left"></i>Versions</button>
                <button class="panel-tab" @onclick="OpenCredits" @onmousedown:stopPropagation><i class="fa-solid fa-heart"></i>Credits</button>
            </div>
        </div>
    }

    <!-- ── VERSIONS PANEL ── -->
    @if (currentView == "versions")
    {
        <div class="panel-overlay">
            <div class="panel-header">
                <div class="panel-title-wrap">
                    <span class="panel-title">Versions</span>
                    <div class="panel-title-underline"></div>
                </div>
                <div class="panel-header-actions">
                    <button class="panel-icon-btn @((versionsClient == "Latite" ? isLoadingVersions : isLoadingOderSoVersions) ? "spinning" : "")"
                            disabled="@(versionsClient == "Latite" ? isLoadingVersions : isLoadingOderSoVersions)"
                            @onclick="RefreshVersionsAsync" @onmousedown:stopPropagation title="Refresh">
                        <i class="fa-solid fa-rotate"></i>
                    </button>
                    <button class="panel-back-btn" @onclick="GoHome" @onmousedown:stopPropagation>
                        <i class="fa-solid fa-chevron-down"></i>
                    </button>
                </div>
            </div>

            <!-- Client switcher -->
            <div class="versions-client-switcher">
                <button class="vcs-btn @(versionsClient == "Latite" ? "active" : "")"
                        @onclick='() => SwitchVersionsClient("Latite")' @onmousedown:stopPropagation>
                    <i class="fa-solid fa-bolt"></i> Latite
                </button>
                <button class="vcs-btn @(versionsClient == "OderSo" ? "active" : "")"
                        @onclick='() => SwitchVersionsClient("OderSo")' @onmousedown:stopPropagation>
                    <i class="fa-solid fa-wand-magic-sparkles"></i> OderSo
                </button>
            </div>

            <div class="panel-search-wrap">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input class="panel-search-input" placeholder="@(versionsClient == "Latite" ? "Filter Latite versions…" : "Filter OderSo versions…")"
                       @bind="versionsFilter" @bind:event="oninput"
                       @onkeydown:stopPropagation />
            </div>

            <div class="panel-body">

                <!-- ── Latite list ── -->
                @if (versionsClient == "Latite")
                {
                    @if (isLoadingVersions)
                    {
                        <div class="versions-loading"><span class="spinner"></span><span>Fetching versions…</span></div>
                    }
                    else if (versions.Count == 0)
                    {
                        <div class="versions-loading"><span style="opacity:0.5;">No versions found.</span></div>
                    }
                    else
                    {
                        var pinnedList   = FilteredVersions.Where(v => IsPinned(v.Tag)).ToList();
                        var unpinnedList = FilteredVersions.Where(v => !IsPinned(v.Tag)).ToList();

                        @if (pinnedList.Count > 0)
                        {
                            <span class="panel-section-label">Pinned</span>
                            @foreach (var v in pinnedList)
                            {
                                <div class="version-row @(v.ErrorMessage != null ? "error-row" : "") pinned">
                                    <div class="version-meta">
                                        <span class="version-name">@v.DisplayName</span>
                                        @if (v.ErrorMessage != null) { <span class="error-text">@v.ErrorMessage</span> }
                                        else if (v.IsDownloaded && !v.IsDownloading) { <span class="version-sub">Ready</span> }
                                    </div>
                                    @if (v.ErrorMessage == null) { @VersionActions(v) }
                                </div>
                            }
                            <span class="panel-section-label">All Versions</span>
                        }

                        @if (unpinnedList.Count == 0 && pinnedList.Count == 0)
                        {
                            <div class="versions-loading"><span style="opacity:0.5;">No results for "@versionsFilter"</span></div>
                        }

                        @foreach (var v in unpinnedList)
                        {
                            <div class="version-row @(v.ErrorMessage != null ? "error-row" : "")">
                                <div class="version-meta">
                                    <span class="version-name">@v.DisplayName</span>
                                    @if (v.ErrorMessage != null) { <span class="error-text">@v.ErrorMessage</span> }
                                    else if (v.IsDownloaded && !v.IsDownloading) { <span class="version-sub">Ready</span> }
                                </div>
                                @if (v.ErrorMessage == null) { @VersionActions(v) }
                            </div>
                        }
                    }
                }

                <!-- ── OderSo list ── -->
                @if (versionsClient == "OderSo")
                {
                    @if (isLoadingOderSoVersions)
                    {
                        <div class="versions-loading"><span class="spinner"></span><span>Fetching OderSo versions…</span></div>
                    }
                    else if (oderSoVersions.Count == 0)
                    {
                        <div class="versions-loading"><span style="opacity:0.5;">No DLLs found in repo.</span></div>
                    }
                    else
                    {
                        var filteredOderSo = string.IsNullOrWhiteSpace(versionsFilter)
                            ? oderSoVersions
                            : oderSoVersions.Where(s => s.DisplayName.Contains(versionsFilter, StringComparison.OrdinalIgnoreCase)).ToList();

                        @if (!filteredOderSo.Any())
                        {
                            <div class="versions-loading"><span style="opacity:0.5;">No results for "@versionsFilter"</span></div>
                        }

                        @foreach (var s in filteredOderSo)
                        {
                            var state = s;
                            <div class="version-row @(state.IsActive ? "oderso-active-row" : "")">
                                <div class="version-meta">
                                    <div style="display:flex; align-items:center; gap:6px;">
                                        <span class="version-name">@state.DisplayName</span>
                                        @if (state.IsActive) { <span class="tag-active">Active</span> }
                                    </div>
                                    @if (!string.IsNullOrEmpty(state.Error)) { <span class="error-text">@state.Error</span> }
                                    else if (state.IsDownloaded && !state.IsDownloading) { <span class="version-sub">Ready · @state.SizeLabel</span> }
                                    else if (!state.IsDownloaded) { <span class="version-sub">@state.SizeLabel</span> }
                                </div>
                                @OderSoVersionActions(state)
                            </div>
                        }
                    }
                }

            </div>
            <div class="panel-tabs">
                <button class="panel-tab" @onclick="OpenSettings" @onmousedown:stopPropagation><i class="fa-solid fa-gear"></i>Settings</button>
                <button class="panel-tab" @onclick="OpenClients" @onmousedown:stopPropagation><i class="fa-solid fa-puzzle-piece"></i>Clients</button>
                <button class="panel-tab active" @onmousedown:stopPropagation><i class="fa-solid fa-clock-rotate-left"></i>Versions</button>
                <button class="panel-tab" @onclick="OpenCredits" @onmousedown:stopPropagation><i class="fa-solid fa-heart"></i>Credits</button>
            </div>
        </div>
    }

    <!-- ── CREDITS PANEL ── -->
    @if (currentView == "credits")
    {
        <div class="panel-overlay">
            <div class="panel-header">
                <div class="panel-title-wrap">
                    <span class="panel-title">Credits</span>
                    <div class="panel-title-underline"></div>
                </div>
                <div class="panel-header-actions">
                    <button class="panel-back-btn" @onclick="GoHome" @onmousedown:stopPropagation>
                        <i class="fa-solid fa-chevron-down"></i>
                    </button>
                </div>
            </div>
            <div class="panel-body">

                <span class="panel-section-label">Launcher</span>

                <div class="credits-card credits-card-glacier">
