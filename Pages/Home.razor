@page "/"
@using GlacierLauncher.Services
@using GlacierLauncher.Models
@inject GameLauncher Launcher
@inject FlarialService Flarial
@inject OderSoService OderSo
@inject AutoUpdateService AutoUpdate
@inject SettingsService SettingsService
@inject DiscordRpcService Discord
@inject IJSRuntime JS
@implements IDisposable

<div class="window">
    <div class="window-bg"></div>
    <div class="drag-zone" @onmousedown="OnDragStart"></div>

    <!-- Drop overlay -->
    <div class="drop-zone-overlay">
        <i class="fa-solid fa-file-arrow-down"></i>
        <span>Drop your DLL</span>
        <small>Saved to clients folder and selected automatically</small>
    </div>

    <!-- ── GLOBAL SEARCH OVERLAY ── -->
    @if (searchOpen)
    {
        <div class="search-overlay" @onclick="CloseSearch">
            <div class="search-modal" @onclick:stopPropagation>
                <div class="search-modal-input-row">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input class="search-modal-input"
                           placeholder="Search clients, versions, settings…"
                           value="@searchQuery"
                           @oninput="OnSearchInput"
                           @onkeydown:stopPropagation />
                    <span class="search-modal-esc">ESC</span>
                </div>
                <div class="search-results">
                    @if (!searchResults.Any())
                    {
                        @if (string.IsNullOrEmpty(searchQuery))
                        {
                            <div class="search-category">Quick Actions</div>
                            @for (int si = 0; si < _defaultSearchResults.Count; si++)
                            {
                                var r = _defaultSearchResults[si];
                                var idx = si;
                                <div class="search-result-item @(searchSelIdx == idx ? "sel" : "")"
                                     @onclick="r.OnSelect"
                                     @onmouseenter="() => searchSelIdx = idx">
                                    <div class="search-result-icon">
                                        @if (r.Icon.StartsWith("images/")) { <img src="@r.Icon" style="width:16px;height:16px;object-fit:contain;" /> }
                                        else { <i class="@r.Icon"></i> }
                                    </div>
                                    <div class="search-result-text">
                                        <span class="search-result-label">@r.Label</span>
                                        @if (!string.IsNullOrEmpty(r.Sub)) { <span class="search-result-sub">@r.Sub</span> }
                                    </div>
                                    @if (!string.IsNullOrEmpty(r.Shortcut))
                                    {
                                        <div class="kbs"><kbd>@r.Shortcut</kbd></div>
                                    }
                                    <span class="search-result-enter">↵</span>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="search-no-results">No results for "<strong>@searchQuery</strong>"</div>
                        }
                    }
                    else
                    {
                        var grouped = searchResults.GroupBy(r => r.Category);
                        int flatIdx = 0;
                        @foreach (var grp in grouped)
                        {
                            <div class="search-category">@grp.Key</div>
                            @foreach (var r in grp)
                            {
                                var fi = flatIdx++;
                                <div class="search-result-item @(searchSelIdx == fi ? "sel" : "")"
                                     @onclick="r.OnSelect"
                                     @onmouseenter="() => searchSelIdx = fi">
                                    <div class="search-result-icon">
                                        @if (r.Icon.StartsWith("images/")) { <img src="@r.Icon" style="width:16px;height:16px;object-fit:contain;" /> }
                                        else { <i class="@r.Icon"></i> }
                                    </div>
                                    <div class="search-result-text">
                                        <span class="search-result-label">@r.Label</span>
                                        @if (!string.IsNullOrEmpty(r.Sub)) { <span class="search-result-sub">@r.Sub</span> }
                                    </div>
                                    <span class="search-result-enter">↵</span>
                                </div>
                            }
                        }
                    }
                </div>
            </div>
        </div>
    }

    <!-- ── LAUNCHER UPDATE MODAL ── -->
    @if (launcherUpdateModalOpen && launcherUpdateInfo != null)
    {
        <div class="modal-overlay" @onclick="CloseUpdateModal">
            <div class="modal-box update-modal" @onclick:stopPropagation>
                <div class="modal-header">
                    <span class="modal-title">
                        <i class="fa-solid fa-rocket" style="color:var(--accent);margin-right:8px;"></i>
                        Update Available
                    </span>
                    <button class="modal-close-btn" @onclick="CloseUpdateModal">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="update-version-row">
                        <div class="update-version-chip current">
                            <span class="uvc-label">Current</span>
                            <span class="uvc-tag">v@(AutoUpdateService.CurrentVersion)</span>
                        </div>
                        <i class="fa-solid fa-arrow-right" style="color:var(--text-dim); font-size:12px;"></i>
                        <div class="update-version-chip next">
                            <span class="uvc-label">Latest</span>
                            <span class="uvc-tag">v@(launcherUpdateInfo.Tag)</span>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(launcherUpdateInfo.Changelog))
                    {
                        <div class="update-changelog">
                            <span class="update-changelog-label">What's new</span>
                            <div class="update-changelog-body">@launcherUpdateInfo.Changelog</div>
                        </div>
                    }

                    @if (launcherUpdating)
                    {
                        <div class="update-progress-wrap">
                            <div class="update-progress-bar">
                                <div class="update-progress-fill" style="width:@(launcherUpdateProgress.ToString("F0"))%"></div>
                            </div>
                            <span class="update-progress-pct">@((int)launcherUpdateProgress)%</span>
                        </div>
                        <p class="modal-desc" style="margin-top:6px;">Downloading update… launcher will restart automatically.</p>
                    }
                    else
                    {
                        <div class="modal-btn-row" style="margin-top:14px;">
                            <button class="modal-btn modal-btn-cancel" @onclick="SkipLauncherUpdate">Skip this version</button>
                            <button class="modal-btn modal-btn-cancel" @onclick="CloseUpdateModal">Later</button>
                            <button class="modal-btn modal-btn-confirm" @onclick="ApplyLauncherUpdate">
                                <i class="fa-solid fa-download"></i> Install &amp; Restart
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- ── DISCORD MODAL ── -->
    @if (discordModalOpen)
    {
        <div class="modal-overlay" @onclick="CloseDiscordModal">
            <div class="modal-box" @onclick:stopPropagation>
                <div class="modal-header">
                    <span class="modal-title"><i class="fa-brands fa-discord" style="color:#7289da;margin-right:8px;"></i>Discord Account</span>
                    <button class="modal-close-btn" @onclick="CloseDiscordModal">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                <div class="modal-body">
                    @if (SettingsService.Settings.DiscordLoggedIn)
                    {
                        <p class="modal-desc">Signed in as <strong style="color:var(--text);">@SettingsService.Settings.DiscordUsername</strong>. Username and avatar will sync to Discord Rich Presence.</p>
                        <div class="modal-btn-row">
                            <button class="modal-btn modal-btn-disconnect" @onclick="DisconnectDiscord">Disconnect</button>
                            <button class="modal-btn modal-btn-cancel" @onclick="CloseDiscordModal">Close</button>
                        </div>
                    }
                    else
                    {
                        <p class="modal-desc">Connect your Discord account to sync your username and avatar with Rich Presence.</p>
                        <button class="discord-oauth-btn" @onclick="OpenDiscordOAuth">
                            <i class="fa-brands fa-discord"></i>
                            Continue with Discord
                        </button>
                        <div class="modal-divider">or enter manually</div>
                        <label class="modal-input-label">Discord Username</label>
                        <input class="modal-input" placeholder="username"
                               @bind="discordUsernameInput" @bind:event="oninput"
                               @onkeydown:stopPropagation />
                        <div class="modal-btn-row">
                            <button class="modal-btn modal-btn-cancel" @onclick="CloseDiscordModal">Cancel</button>
                            <button class="modal-btn modal-btn-confirm" @onclick="SaveDiscordManual"
                                    disabled="@(string.IsNullOrWhiteSpace(discordUsernameInput))">Save</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- ── TOP BAR ── -->
    <div class="top-bar">
        <div class="branding">
            <img class="logo-icon" src="images/icon.png" alt="" />
            <div class="branding-text">
                <span class="branding-title">Glacier Launcher</span>
                <span class="branding-sub">Glacier Productions</span>
            </div>
            @if (launcherUpdateAvailable)
            {
                <button class="update-pill" @onclick="OpenUpdateModal" @onmousedown:stopPropagation title="Launcher update available — click to update">
                    <i class="fa-solid fa-arrow-up"></i>
                    <span>Update</span>
                </button>
            }
            else
            {
                <span class="version-pill" title="Glacier Launcher v@(AutoUpdateService.CurrentVersion)">v@(AutoUpdateService.CurrentVersion)</span>
            }
        </div>

        <div class="top-bar-spacer"></div>

        <!-- Quick client switcher chip (inline, left of controls) -->
        <div class="topbar-client-chip" @onclick="CycleClient" @onmousedown:stopPropagation
             title="Click to cycle client (@SettingsService.Settings.SelectedClient)">
            <div class="chip-dot"></div>
            @if (SettingsService.Settings.SelectedClient == "Custom DLL")
            {
                <i class="chip-icon @(GetClientIcon(SettingsService.Settings.SelectedClient))"></i>
            }
            else
            {
                <img class="chip-icon" src="@GetClientImagePath(SettingsService.Settings.SelectedClient)" style="width:14px;height:14px;object-fit:contain;" alt="" />
            }
            <span>@SettingsService.Settings.SelectedClient</span>
            <i class="fa-solid fa-chevron-right chip-arrow"></i>
        </div>

        <!-- Quick search trigger (inline, left of controls) -->
        <button class="search-trigger" @onclick="OpenSearch" @onmousedown:stopPropagation title="Search (Ctrl+K)">
            <i class="fa-solid fa-magnifying-glass"></i>
            <kbd>Ctrl K</kbd>
        </button>

        <div class="window-controls">
            <button class="wnd-btn minimize-btn" @onclick="MinimizeWindow" @onmousedown:stopPropagation title="Minimize">
                <i class="fa-solid fa-minus"></i>
            </button>
            <button class="wnd-btn maximize-btn" @onclick="MaximizeWindow" @onmousedown:stopPropagation title="Maximize">
                <i class="fa-solid fa-square"></i>
            </button>
            <button class="wnd-btn close-btn" @onclick="CloseWindow" @onmousedown:stopPropagation title="Close">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
    </div>

    <!-- ── MAIN CONTENT ── -->
    <div class="main-content">
        @if (currentView == "home")
        {
            <div class="btn-row">
                <button class="action-btn @(hoveredBtn == "launch" || isLaunching ? "btn-wide btn-blue" : "btn-sq") @(isLaunching ? "launching" : "")"
                        @onmouseenter='() => SetHover("launch")' @onmouseleave="ClearHover"
                        @onclick="HandleLaunch" @onmousedown:stopPropagation disabled="@isLaunching">
                    @if (hoveredBtn == "launch" || isLaunching)
                    {
                        @if (isLaunching) { <span class="spinner"></span><span>Launching…</span> }
                        else              { <span>Launch</span> }
                    }
                    else { <i class="fa-solid fa-play"></i> }
                </button>

                <div class="btn-badge-wrap">
                    <button class="action-btn @(hoveredBtn == "settings" ? "btn-wide" : "btn-sq")"
                            @onmouseenter='() => SetHover("settings")' @onmouseleave="ClearHover"
                            @onclick="OpenSettings" @onmousedown:stopPropagation>
                        @if (hoveredBtn == "settings") { <span>Settings</span> }
                        else { <i class="fa-solid fa-gear"></i> }
                    </button>
                </div>

                <div class="btn-badge-wrap">
                    <button class="action-btn @(hoveredBtn == "clients" ? "btn-wide" : "btn-sq")"
                            @onmouseenter='() => SetHover("clients")' @onmouseleave="ClearHover"
                            @onclick="OpenClients" @onmousedown:stopPropagation>
                        @if (hoveredBtn == "clients") { <span>Clients</span> }
                        else { <i class="fa-solid fa-puzzle-piece"></i> }
                    </button>
                    @if (clientsHasBadge) { <span class="notification-badge"></span> }
                </div>

                <div class="btn-badge-wrap">
                    <button class="action-btn @(hoveredBtn == "versions" ? "btn-wide" : "btn-sq")"
                            @onmouseenter='() => SetHover("versions")' @onmouseleave="ClearHover"
                            @onclick="OpenVersions" @onmousedown:stopPropagation>
                        @if (hoveredBtn == "versions") { <span>Versions</span> }
                        else { <i class="fa-solid fa-clock-rotate-left"></i> }
                    </button>
                    @if (versionsHasBadge) { <span class="notification-badge"></span> }
                </div>
            </div>

            <p class="status-msg @(isError ? "error" : "") @(statusVisible ? "visible" : "")">@statusMessage</p>

            @if (SettingsService.Settings.ShowRecentlyLaunched && SettingsService.Settings.RecentlyLaunched.Count > 0)
            {
                <div class="recently-launched">
                    <span class="recently-label">Recent:</span>
                    @foreach (var item in SettingsService.Settings.RecentlyLaunched.Take(3))
                    {
                        var itemCopy = item;
                        <button class="recent-item"
                                @onclick="() => QuickLaunchRecent(itemCopy)"
                                @onmousedown:stopPropagation>
                            <i class="fa-solid fa-clock-rotate-left"></i>@item
                        </button>
                    }
                </div>
            }
        }
    </div>

    <!-- ── FOOTER ── -->
    <div class="footer">
        <img class="avatar @(SettingsService.Settings.DiscordLoggedIn ? "discord-connected" : "")"
             src="@(GetAvatarSrc())" alt=""
             @onclick="OpenDiscordModal" @onmousedown:stopPropagation />
        <div class="user-info">
            <span class="username">@displayName</span>
            <span class="user-handle">@displayHandle</span>
        </div>
        <div class="footer-right">
            @if (SettingsService.Settings.DiscordLoggedIn)
            {
                <div class="discord-connected-pill" @onclick="OpenDiscordModal" style="cursor:pointer;">
                    <i class="fa-brands fa-discord"></i>
                    <span>@SettingsService.Settings.DiscordUsername</span>
                </div>
            }
            else
            {
                <button class="discord-connect-btn" @onclick="OpenDiscordModal" @onmousedown:stopPropagation>
                    <i class="fa-brands fa-discord"></i>
                    Connect
                </button>
            }
            @if (!string.IsNullOrEmpty(SettingsService.Settings.LastUsedVersion))
            {
                <span style="font-size:11px; color:var(--text-dim);">
                    <i class="fa-solid fa-clock" style="margin-right:4px;"></i>@SettingsService.Settings.LastUsedVersion
                </span>
            }
        </div>
    </div>

    <!-- Toast container -->
    <div class="toast-container">
        @foreach (var t in _toasts)
        {
            <div class="toast @(t.Kind)">
                <i class="@(t.Icon)"></i>
                @t.Message
            </div>
        }
    </div>

    <!-- News ticker -->
    <div class="news-strip">
        <div class="news-track">
            @foreach (var item in _newsItems)
            {
                <span class="news-item" @onclick='() => OpenUrl(item.Url)'>
                    <i class="@item.Icon"></i>
                    <span class="news-title">@item.Title</span>
                    <span>@item.Subtitle</span>
                </span>
            }
            @foreach (var item in _newsItems)
            {
                <span class="news-item" @onclick='() => OpenUrl(item.Url)'>
                    <i class="@item.Icon"></i>
                    <span class="news-title">@item.Title</span>
                    <span>@item.Subtitle</span>
                </span>
            }
        </div>
    </div>

    <!-- ── SETTINGS PANEL ── -->
    @if (currentView == "settings")
    {
        <div class="panel-overlay">
            <div class="panel-header">
                <div class="panel-title-wrap">
                    <span class="panel-title">Settings</span>
                    <div class="panel-title-underline"></div>
                </div>
                <div class="panel-header-actions">
                    <button class="panel-back-btn" @onclick="GoHome" @onmousedown:stopPropagation>
                        <i class="fa-solid fa-chevron-down"></i>
                    </button>
                </div>
            </div>
            <div class="panel-search-wrap">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input class="panel-search-input" placeholder="Filter settings…"
                       @bind="settingsFilter" @bind:event="oninput"
                       @onkeydown:stopPropagation />
            </div>
            <div class="panel-body">

                <span class="panel-section-label">Injection</span>

                <div class="setting-row @(SH("Active client","active client injection"))">
                    <span class="setting-label">Active client</span>
                    <select class="setting-select" value="@SettingsService.Settings.SelectedClient"
                            @onchange="OnClientChanged" @onclick:stopPropagation>
                        <option value="Latite Client">Latite Client</option>
                        <option value="Flarial Client">Flarial Client</option>
                        <option value="OderSo Client">OderSo Client</option>
                        @if (!string.IsNullOrEmpty(customDllPath))
                        {
                            <option value="Custom DLL">Custom DLL</option>
                        }
                    </select>
                </div>

                <div class="setting-row @(SH("Injection delay","injection delay wait"))">
                    <div class="setting-meta">
                        <span class="setting-label">Injection delay</span>
                        <span class="setting-hint">How long to wait after game launches before injecting</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:8px;">
                        <input type="range" min="1000" max="10000" step="500"
                               value="@SettingsService.Settings.InjectionDelayMs"
                               @oninput="OnDelayChanged" />
                        <span style="font-size:11px; color:var(--text-dim); width:38px; text-align:right;">
                            @(SettingsService.Settings.InjectionDelayMs / 1000.0)s
                        </span>
                    </div>
                </div>

                <div class="setting-row clickable @(SH("Auto-inject","auto inject automatic"))"
                     @onclick='() => ToggleProp(() => SettingsService.Settings.AutoInject = !SettingsService.Settings.AutoInject)'>
                    <div class="setting-meta">
                        <span class="setting-label">Auto-inject</span>
                        <span class="setting-hint">Inject automatically once the game process is detected</span>
                    </div>
                    <div class="toggle @(SettingsService.Settings.AutoInject ? "on" : "")"
                         @onclick:stopPropagation
                         @onclick='() => ToggleProp(() => SettingsService.Settings.AutoInject = !SettingsService.Settings.AutoInject)'></div>
                </div>

                <div class="setting-row clickable @(SH("Close after launch","close minimize launch"))"
                     @onclick='() => ToggleProp(() => SettingsService.Settings.CloseAfterLaunch = !SettingsService.Settings.CloseAfterLaunch)'>
                    <div class="setting-meta">
                        <span class="setting-label">Close after launch</span>
                        <span class="setting-hint">Minimise the launcher once injection succeeds</span>
                    </div>
                    <div class="toggle @(SettingsService.Settings.CloseAfterLaunch ? "on" : "")"
                         @onclick:stopPropagation
                         @onclick='() => ToggleProp(() => SettingsService.Settings.CloseAfterLaunch = !SettingsService.Settings.CloseAfterLaunch)'></div>
                </div>

                <span class="panel-section-label">Appearance</span>

                <div class="setting-row @(SH("Accent colour","accent color theme"))">
                    <div class="setting-meta">
                        <span class="setting-label">Accent colour</span>
                        <span class="setting-hint">Used for buttons, highlights and glows</span>
                    </div>
                    <div class="color-swatches">
                        @foreach (var c in _accentSwatches)
                        {
                            <div class="color-swatch @(SettingsService.Settings.AccentColor == c ? "active" : "")"
                                 style="background:@c;" title="@c"
                                 @onclick='() => SetAccent(c)'
                                 @onmousedown:stopPropagation></div>
                        }
                    </div>
                </div>

                <div class="setting-row @(SH("Theme preset","theme dark midnight slate"))">
                    <div class="setting-meta">
                        <span class="setting-label">Theme preset</span>
                        <span class="setting-hint">Background darkness level</span>
                    </div>
                    <select class="setting-select" value="@SettingsService.Settings.ThemePreset"
                            @onchange="OnThemeChanged" @onclick:stopPropagation>
                        <option value="dark">Dark</option>
                        <option value="darker">Darker</option>
                        <option value="midnight">Midnight</option>
                        <option value="slate">Slate</option>
                    </select>
                </div>

                <div class="setting-row @(SH("Background blur","blur background"))">
                    <div class="setting-meta">
                        <span class="setting-label">Background blur</span>
                        <span class="setting-hint">Backdrop blur intensity for panels</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:8px;">
                        <input type="range" min="0" max="30" step="2"
                               value="@SettingsService.Settings.BlurIntensity"
                               @oninput="OnBlurChanged" />
                        <span style="font-size:11px; color:var(--text-dim); width:32px; text-align:right;">
                            @(SettingsService.Settings.BlurIntensity)px
                        </span>
                    </div>
                </div>

                <div class="setting-row clickable @(SH("Remember window size","window size remember"))"
                     @onclick='() => ToggleProp(() => SettingsService.Settings.RememberWindowSize = !SettingsService.Settings.RememberWindowSize)'>
                    <div class="setting-meta">
                        <span class="setting-label">Remember window size</span>
                        <span class="setting-hint">Restore last used size on next launch</span>
                    </div>
                    <div class="toggle @(SettingsService.Settings.RememberWindowSize ? "on" : "")"
                         @onclick:stopPropagation
                         @onclick='() => ToggleProp(() => SettingsService.Settings.RememberWindowSize = !SettingsService.Settings.RememberWindowSize)'></div>
                </div>

                <div class="setting-row @(SH("Custom background wallpaper","background wallpaper image custom"))">
                    <div class="setting-meta">
                        <span class="setting-label">Background wallpaper</span>
                        <span class="setting-hint">
                            @if (!string.IsNullOrEmpty(SettingsService.Settings.CustomBackgroundPath))
                            {
                                @("Custom — " + System.IO.Path.GetFileName(SettingsService.Settings.CustomBackgroundPath))
                            }
                            else
                            {
                                @("Default background")
                            }
                        </span>
                    </div>
                    <div style="display:flex; align-items:center; gap:6px;">
                        @if (!string.IsNullOrEmpty(SettingsService.Settings.CustomBackgroundPath))
                        {
                            <button class="btn-sm" @onclick="ResetWallpaper" @onmousedown:stopPropagation title="Reset to default">
                                <i class="fa-solid fa-rotate-left"></i> Default
                            </button>
                        }
                        <button class="btn-sm" @onclick="PickWallpaper" @onmousedown:stopPropagation title="Choose image or drag & drop">
                            <i class="fa-solid fa-image"></i> Choose
                        </button>
                    </div>
                </div>

                <span class="panel-section-label">Account</span>

                <div class="setting-row @(SH("Display name","username name display account"))">
                    <span class="setting-label">Display name</span>
                    <input class="setting-input" style="width:130px;"
                           value="@SettingsService.Settings.Username"
                           placeholder="@System.Environment.UserName"
                           @onchange="OnUsernameChanged"
                           @onclick:stopPropagation />
                </div>

                <span class="panel-section-label">Social</span>

                <div class="setting-row clickable @(SH("Discord Rich Presence","discord rpc social"))"
                     @onclick='() => ToggleProp(() => SettingsService.Settings.DiscordRichPresence = !SettingsService.Settings.DiscordRichPresence, true)'>
                    <span class="setting-label">Discord Rich Presence</span>
                    <div class="toggle @(SettingsService.Settings.DiscordRichPresence ? "on" : "")"
                         @onclick:stopPropagation
                         @onclick='() => ToggleProp(() => SettingsService.Settings.DiscordRichPresence = !SettingsService.Settings.DiscordRichPresence, true)'></div>
                </div>

                <div class="setting-row clickable @(SH("Discord account","discord login account"))"
                     @onclick="OpenDiscordModal">
                    <div class="setting-meta">
                        <span class="setting-label">Discord account</span>
                        <span class="setting-hint">@(SettingsService.Settings.DiscordLoggedIn ? "Connected as " + SettingsService.Settings.DiscordUsername : "Not connected")</span>
                    </div>
                    <button class="btn-sm" @onclick:stopPropagation @onclick="OpenDiscordModal">
                        <i class="fa-brands fa-discord"></i>
                        @(SettingsService.Settings.DiscordLoggedIn ? "Manage" : "Connect")
                    </button>
                </div>

                <span class="panel-section-label">Quality of Life</span>

                <div class="setting-row clickable @(SH("Show recently launched","recent history"))"
                     @onclick='() => ToggleProp(() => SettingsService.Settings.ShowRecentlyLaunched = !SettingsService.Settings.ShowRecentlyLaunched)'>
                    <div class="setting-meta">
                        <span class="setting-label">Show recently launched</span>
                        <span class="setting-hint">Quick-access chips on the home screen</span>
                    </div>
                    <div class="toggle @(SettingsService.Settings.ShowRecentlyLaunched ? "on" : "")"
                         @onclick:stopPropagation
                         @onclick='() => ToggleProp(() => SettingsService.Settings.ShowRecentlyLaunched = !SettingsService.Settings.ShowRecentlyLaunched)'></div>
                </div>

                <div class="setting-row clickable @(SH("Minimize to tray","tray minimize system"))"
                     @onclick='() => ToggleProp(() => SettingsService.Settings.MinimizeToTray = !SettingsService.Settings.MinimizeToTray)'>
                    <div class="setting-meta">
                        <span class="setting-label">Minimize to tray</span>
                        <span class="setting-hint">Minimize button sends to system tray</span>
                    </div>
                    <div class="toggle @(SettingsService.Settings.MinimizeToTray ? "on" : "")"
                         @onclick:stopPropagation
                         @onclick='() => ToggleProp(() => SettingsService.Settings.MinimizeToTray = !SettingsService.Settings.MinimizeToTray)'></div>
                </div>

                <div class="setting-row @(SH("Clear recent history","clear history recent"))">
                    <div class="setting-meta">
                        <span class="setting-label">Clear recent history</span>
                        <span class="setting-hint">@(SettingsService.Settings.RecentlyLaunched.Count) item(s)</span>
                    </div>
                    <button class="btn-sm" @onclick="ClearRecentHistory" @onmousedown:stopPropagation>
                        <i class="fa-solid fa-trash"></i> Clear
                    </button>
                </div>

                <span class="panel-section-label">Updates</span>

                <div class="setting-row clickable @(SH("Check for updates on startup","update auto check startup"))"
                     @onclick='() => ToggleProp(() => SettingsService.Settings.CheckUpdatesOnStartup = !SettingsService.Settings.CheckUpdatesOnStartup)'>
                    <div class="setting-meta">
                        <span class="setting-label">Check for updates on startup</span>
                        <span class="setting-hint">Silently checks launcher + client updates in the background</span>
                    </div>
                    <div class="toggle @(SettingsService.Settings.CheckUpdatesOnStartup ? "on" : "")"
                         @onclick:stopPropagation
                         @onclick='() => ToggleProp(() => SettingsService.Settings.CheckUpdatesOnStartup = !SettingsService.Settings.CheckUpdatesOnStartup)'></div>
                </div>

                <div class="setting-row @(SH("Check for updates now","update manual check"))">
                    <div class="setting-meta">
                        <span class="setting-label">Check for updates now</span>
                        <span class="setting-hint">@(checkingUpdatesManual ? "Checking…" : lastUpdateCheckLabel)</span>
                    </div>
                    <button class="btn-sm" @onclick="ManualUpdateCheck" @onmousedown:stopPropagation
                            disabled="@checkingUpdatesManual">
                        @if (checkingUpdatesManual) { <span class="spinner" style="width:11px;height:11px;border-width:1.5px;"></span> }
                        else { <i class="fa-solid fa-rotate"></i> }
                        Check
