                    var canDirect   = LunarBadlion.CanDirectLaunchLunar;
                }
                <div class="credits-card">
                    <div class="credits-card-icon" style="background:#06b6d422; color:#22d3ee;">
                        <i class="fa-solid fa-moon"></i>
                    </div>
                    <div class="credits-card-meta">
                        <span class="credits-card-name">Lunar Client <span style="opacity:0.55; font-weight:500;">incl. Badlion</span></span>
                        <span class="credits-card-sub">
                            @if (lbInstalled && canDirect)
                            {
                                <text>Direct launch ready Â· @(LunarBadlion.LunarInstalledVersions.Length) version(s) installed offline</text>
                            }
                            else if (lbInstalled)
                            {
                                <text>Detected Â· @(LunarBadlion.LunarExePath ?? LunarBadlion.BadlionExePath) â€” first launch may show the Lunar splash</text>
                            }
                            else
                            {
                                <text>Not installed â€” download from lunarclient.com (Lunar's purchase of Badlion lets one app cover both)</text>
                            }
                        </span>
                    </div>
                    <div class="credits-card-actions">
                        @if (lbInstalled && canDirect)
                        {
                            <select class="setting-select" @bind="lunarSelectedVersion" @onclick:stopPropagation>
                                @foreach (var lv in LunarBadlion.LunarInstalledVersions)
                                {
                                    <option value="@lv">@lv</option>
                                }
                            </select>
                            <button class="vcs-btn" @onclick='() => LaunchLunarDirect()' @onmousedown:stopPropagation>
                                <i class="fa-solid fa-bolt"></i> Launch
                            </button>
                        }
                        else if (lbInstalled)
                        {
                            <button class="vcs-btn" @onclick='() => LaunchLunar()' @onmousedown:stopPropagation>
                                <i class="fa-solid fa-play"></i> Launch
                            </button>
                        }
                        else
                        {
                            <button class="vcs-btn vcs-btn-ghost" @onclick='() => OpenUrl("https://www.lunarclient.com")' @onmousedown:stopPropagation>
                                <i class="fa-solid fa-arrow-up-right-from-square"></i> Get it
                            </button>
