    <!-- â”€â”€ JAVA VERSIONS PANEL â”€â”€ -->
    @if (currentView == "javaversions")
    {
        <div class="panel-overlay">
            <div class="panel-handle"></div>
            <div class="panel-header">
                <div class="panel-title-wrap">
                    <span class="panel-title">Versions</span>
                    <div class="panel-title-underline"></div>
                </div>
                <div class="panel-header-actions">
                    <button class="panel-icon-btn @(SettingsService.Settings.JavaShowSnapshots ? "active" : "")"
                            @onclick="ToggleJavaSnapshots" @onmousedown:stopPropagation
                            data-tooltip="@(SettingsService.Settings.JavaShowSnapshots ? "Hide snapshots" : "Show snapshots")">
                        <i class="fa-solid fa-flask"></i>
                    </button>
                    <button class="panel-icon-btn @(SettingsService.Settings.JavaShowHistorical ? "active" : "")"
                            @onclick="ToggleJavaHistorical" @onmousedown:stopPropagation
                            data-tooltip="@(SettingsService.Settings.JavaShowHistorical ? "Hide beta/alpha" : "Show beta/alpha")">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                    </button>
                    <button class="panel-icon-btn @(isLoadingJavaVersions ? "spinning" : "")"
                            disabled="@isLoadingJavaVersions"
                            @onclick="RefreshJavaVersionsAsync" @onmousedown:stopPropagation data-tooltip="Refresh">
                        <i class="fa-solid fa-rotate"></i>
                    </button>
                    <button class="panel-back-btn" @onclick="GoHome" @onmousedown:stopPropagation data-tooltip="Back">
                        <i class="fa-solid fa-chevron-down"></i>
                    </button>
                </div>
            </div>

            <!-- Edition switcher (mirrors the Latite/OderSo pattern of the Bedrock panel) -->
            <div class="versions-client-switcher">
                <button class="vcs-btn active" @onmousedown:stopPropagation>
                    <i class="fa-brands fa-java"></i> Vanilla
                </button>
            </div>

            <div class="panel-search-wrap">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input class="panel-search-input" placeholder="Filter Java versions (e.g. 1.21, 1.8.9)..."
                       @bind="javaVersionsFilter" @bind:event="oninput"
                       @onkeydown:stopPropagation />
            </div>

            <div class="panel-body">
                @if (isLoadingJavaVersions)
                {
                    <div class="versions-loading"><span class="spinner"></span><span>Fetching Java versions...</span></div>
                }
                else if (javaVersionsList.Count == 0 && !string.IsNullOrEmpty(javaVersionsError))
                {
                    <div class="versions-loading versions-error">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        <span>@javaVersionsError</span>
                        <button class="vcs-btn" style="margin-top:8px;" @onclick="RefreshJavaVersionsAsync">
                            <i class="fa-solid fa-rotate"></i> Retry
                        </button>
                    </div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(javaVersionsError) && javaVersionsList.Count > 0)
                    {
                        <div class="cache-notice"><i class="fa-solid fa-circle-info"></i><span>@javaVersionsError</span></div>
                    }

                    var filtered = FilteredJavaVersions.ToList();
                    var installed = filtered.Where(v => v.IsInstalled).ToList();
                    var others    = filtered.Where(v => !v.IsInstalled).ToList();

                    @if (installed.Count > 0)
                    {
                        <span class="panel-section-label">Installed (@installed.Count)</span>
                        @foreach (var v in installed)
                        {
                            <div class="version-row @(v.IsActive ? "mcv-active-row" : "")">
                                <div class="version-meta">
                                    <div style="display:flex; align-items:center; gap:6px;">
                                        <span class="version-name">Minecraft @v.Id</span>
                                        @if (v.IsActive) { <span class="tag-active">Active</span> }
                                        <span class="version-sub" style="opacity:0.6;">@v.TypeLabel</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(v.ErrorMessage)) { <span class="error-text">@v.ErrorMessage</span> }
                                    else if (v.HasJar) { <span class="version-sub">Ready to launch</span> }
                                    else { <span class="version-sub" style="color:var(--orange);">Profile present but jar missing â€” open in official launcher once</span> }
                                </div>
                                <button class="vcs-btn" @onclick='() => HandleJavaLaunch(v)'
                                        disabled="@(v.IsLaunching || !v.HasJar)" @onmousedown:stopPropagation>
                                    @if (v.IsLaunching) { <span class="spinner"></span><span>Launching...</span> }
                                    else { <i class="fa-solid fa-play"></i><span>&nbsp;Launch</span> }
                                </button>
                                <button class="vcs-btn vcs-btn-ghost" @onclick='() => SetActiveJavaVersion(v)'
                                        @onmousedown:stopPropagation data-tooltip="Set as default">
                                    <i class="fa-solid fa-thumbtack"></i>
                                </button>
                            </div>
                        }
                    }

                    @if (others.Count > 0)
                    {
                        <span class="panel-section-label">Available (@others.Count)</span>
                        @foreach (var v in others)
                        {
                            <div class="version-row @(!string.IsNullOrEmpty(v.ErrorMessage) ? "error-row" : "")">
                                <div class="version-meta">
                                    <span class="version-name">Minecraft @v.Id</span>
                                    @if (!string.IsNullOrEmpty(v.ErrorMessage))
                                    {
                                        <span class="error-text">@v.ErrorMessage</span>
                                    }
                                    else if (v.IsInstalling)
                                    {
                                        <span class="version-sub">@v.InstallStage</span>
                                    }
                                    else
                                    {
                                        <span class="version-sub" style="opacity:0.6;">@v.TypeLabel @(string.IsNullOrEmpty(v.ReleaseTime) ? "" : "Â· " + v.ReleaseTime[..Math.Min(10, v.ReleaseTime.Length)])</span>
                                    }
                                </div>
                                @if (v.IsInstalling)
                                {
                                    <div class="progress-bar-wrap">
                                        <div class="progress-bar-fill" style="width:@($"{v.InstallPercent:F0}%")"></div>
                                    </div>
                                    <span class="dl-pct">@($"{(int)v.InstallPercent}%")</span>
                                }
                                else
                                {
                                    <button class="vcs-btn" @onclick='() => HandleJavaInstall(v)' @onmousedown:stopPropagation>
                                        <i class="fa-solid fa-download"></i>&nbsp;Install
                                    </button>
                                }
                            </div>
                        }
                    }

                    @if (installed.Count == 0 && others.Count == 0)
                    {
                        <div class="versions-loading"><span style="opacity:0.5;">No results for "@javaVersionsFilter"</span></div>
                    }
                }
            </div>

            <div class="panel-tabs">
                <button class="panel-tab" @onclick="OpenSettings" @onmousedown:stopPropagation><i class="fa-solid fa-gear"></i>Settings</button>
                <button class="panel-tab" @onclick="OpenJavaClients" @onmousedown:stopPropagation><i class="fa-solid fa-rocket"></i>Launchers</button>
                <button class="panel-tab" @onclick="OpenAddons" @onmousedown:stopPropagation><i class="fa-solid fa-puzzle-piece"></i>Mods</button>
                <button class="panel-tab active" @onmousedown:stopPropagation><i class="fa-solid fa-box-archive"></i>Versions</button>
                <button class="panel-tab" @onclick="OpenCredits" @onmousedown:stopPropagation><i class="fa-solid fa-heart"></i>Credits</button>
            </div>
        </div>
    }

