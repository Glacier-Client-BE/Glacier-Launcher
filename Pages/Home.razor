                                <i class="fa-solid fa-rotate"></i> Retry
                            </button>
                        </div>
                    }
                    else if (cfResults.Count == 0 && cfHasSearched)
                    {
                        <div class="empty-state">
                            <i class="fa-solid fa-box-open"></i>
